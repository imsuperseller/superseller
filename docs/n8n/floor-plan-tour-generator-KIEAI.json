{
    "name": "Floor Plan to Photorealistic Property Tour Generator (Kie.ai)",
    "nodes": [
        {
            "parameters": {
                "formTitle": "Upload Floor Plan for Visualization",
                "formFields": {
                    "values": [
                        {
                            "fieldName": "floorPlan",
                            "fieldLabel": "Floor Plan Image",
                            "fieldType": "file",
                            "multipleFiles": false
                        }
                    ]
                },
                "options": {
                    "appendAttribution": false
                }
            },
            "id": "form-trigger",
            "name": "Upload Floor Plan Form",
            "type": "n8n-nodes-base.formTrigger",
            "typeVersion": 2.4,
            "position": [
                -1200,
                300
            ],
            "webhookId": "floor-plan-tour-generator"
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "id-1",
                            "name": "isometricPrompt",
                            "value": "Top-down, fully 3D isometric render of the entire floor plan. Create a clean, highly detailed miniature architectural maquette with accurate room proportions and layout. Remove all text labels. Use colorful, modern furniture and decorative objects in each room—sofas, beds, tables, cabinets, lamps, plants, rugs, appliances—arranged realistically and in scale. High-resolution, photorealistic materials (wood floors, tiles, fabrics, glass). Soft global lighting, subtle shadows, crisp edges. Professional, polished, high-quality output.",
                            "type": "string"
                        },
                        {
                            "id": "id-2",
                            "name": "livingRoomPrompt",
                            "value": "Eye-level photorealistic render of a modern living room interior. Comfortable seating with plush sofas, elegant coffee table, wall-mounted entertainment center, warm ambient lighting from multiple sources, contemporary decor with plants and art. High-quality materials: wood floors, fabric textures, glass surfaces. Natural daylight streaming through windows. Ultra-realistic, 8K quality.",
                            "type": "string"
                        },
                        {
                            "id": "id-3",
                            "name": "kitchenPrompt",
                            "value": "Eye-level photorealistic render of a modern kitchen interior. Sleek white cabinets with marble countertops, stainless steel appliances, central island with bar stools, pendant lighting, clean minimalist design. Morning light through window. Ultra-realistic materials and textures, 8K quality.",
                            "type": "string"
                        },
                        {
                            "id": "id-4",
                            "name": "bedroomPrompt",
                            "value": "Eye-level photorealistic render of a modern master bedroom interior. Comfortable king-size bed with premium bedding, matching nightstands with lamps, spacious wardrobe, soft ambient lighting, cozy atmosphere with neutral tones. Large windows with sheer curtains. Ultra-realistic, 8K quality.",
                            "type": "string"
                        },
                        {
                            "id": "id-5",
                            "name": "patioPrompt",
                            "value": "Eye-level photorealistic render of an outdoor patio terrace. Comfortable outdoor furniture with cushions, potted plants and greenery, string lights, inviting atmosphere for relaxation. Golden hour lighting. Ultra-realistic, 8K quality.",
                            "type": "string"
                        },
                        {
                            "id": "id-6",
                            "name": "livingRoomVideoPrompt",
                            "value": "Smooth cinematic camera slowly panning across the living room, gentle movement showcasing the space from multiple angles, natural lighting changes subtly, professional real estate video style",
                            "type": "string"
                        },
                        {
                            "id": "id-7",
                            "name": "kitchenVideoPrompt",
                            "value": "Smooth cinematic camera gliding through the kitchen, showcasing countertops and appliances, subtle reflections on surfaces, professional interior photography movement",
                            "type": "string"
                        },
                        {
                            "id": "id-8",
                            "name": "bedroomVideoPrompt",
                            "value": "Smooth cinematic camera movement through the bedroom, warm cozy atmosphere, soft lighting ambiance, professional real estate walkthrough style",
                            "type": "string"
                        },
                        {
                            "id": "id-9",
                            "name": "patioVideoPrompt",
                            "value": "Smooth cinematic camera panning across the patio, outdoor ambiance, gentle breeze effect on plants, golden hour lighting, inviting outdoor living space",
                            "type": "string"
                        }
                    ]
                },
                "includeOtherFields": true,
                "options": {}
            },
