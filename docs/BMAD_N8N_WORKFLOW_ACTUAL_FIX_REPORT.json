        {
          "parameters": {
            "jsCode": "const aiResponse = JSON.parse($input.first().json.output);\nconst payload = {\n  title: aiResponse.title,\n  slug: aiResponse.slug,\n  status: 'draft',\n  content: '<main>' + aiResponse.sections.map(s => s.html).join('') + '</main><script type=\"application/ld+json\">' + JSON.stringify(aiResponse.schema) + '</script>',\n  meta: {\n    og_description: aiResponse.og.description\n  },\n  acf: {\n    cta_label: aiResponse.cta.label,\n    cta_href: aiResponse.cta.href\n  }\n};\n\nreturn {\n  payload,\n  specId: aiResponse.id,\n  language: $('Extract Spec Data').first().json.language\n};"
          },
