            "jsCode": "const row = $input.first().json;\nconst id = row['Spec ID'];\nconst l = row.Language;\nconst t = (l == 'he' ? row['Title HE'] : row['Title EN']);\nconst s = (l == 'he' ? row['Slug HE'] : row['Slug EN']);\n\nreturn { id, language: l, title: t, slug: s, originalData: row };"
