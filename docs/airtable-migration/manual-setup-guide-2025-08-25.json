          },
          {
            "table": "Tasks",
            "view": "My Tasks",
            "filter": "Assigned To = Current User"
          }
        ]
      },
      {
        "step": 3,
        "title": "Create Relationships",
        "description": "Set up linked record fields to connect tables",
        "relationships": [
          {
            "from": "Projects",
            "field": "Name",
            "to": "Customers"
          },
          {
            "from": "Invoices",
            "field": "Name",
            "to": "Customers"
          },
          {
            "from": "Invoices",
            "field": "Project Name",
            "to": "Projects"
          },
          {
            "from": "Tasks",
