# SuperSeller AI Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ============================================
# 🔐 AUTHENTICATION & SECURITY
# ============================================
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
DEFAULT_ADMIN_EMAIL=shai@superseller.agency
DEFAULT_ADMIN_PASSWORD=generate-secure-password-here

# OAuth State Management
OAUTH_STATE_SECRET=generate-with-openssl-rand-base64-32

# Credential Encryption
CREDENTIAL_ENCRYPTION_KEY=generate-with-openssl-rand-hex-64

# ============================================
# 💳 PAYMENT INTEGRATIONS
# ============================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# QuickBooks OAuth
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_REDIRECT_URI=https://yourdomain.com/api/oauth/quickbooks-callback

# Credit-based gating (invoice.paid subscription resets)
CREDITS_PER_SUBSCRIPTION_CYCLE=500

# ============================================
# 🗄️ DATABASE & STORAGE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/superseller
AIRTABLE_PAT=pat...

# PostgreSQL (when migrating from Firebase – put real creds only in .env or Vault)
POSTGRES_USER=admin
POSTGRES_DB=app_db
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (when used – put real password only in .env or Vault)
REDIS_PASSWORD=your-redis-password-here
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# 🤖 AI & AUTOMATION
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# 📊 ANALYTICS & MONITORING
# ============================================
NOTION_API_TOKEN=secret_...

# ============================================
# 🌐 INFRASTRUCTURE
# ============================================
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_URL=https://your-n8n-instance.com

# Video pipeline (TourReel)
VIDEO_WORKER_URL=http://localhost:3001
VIDEO_CREDIT_COST=50

# ============================================
# 🎬 WORKER — Video Pipeline (apps/worker)
# ============================================
# AI Services
KIE_API_KEY=your-kie-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=tour-videos
R2_PUBLIC_URL=https://pub-xxx.r2.dev
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Stripe (worker-side)
# STRIPE_SECRET_KEY already defined above
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx
STRIPE_METER_ID=meter_xxx

# Email notifications
RESEND_API_KEY=re_xxx
NOTIFICATION_FROM_EMAIL=noreply@superseller.agency

# Admin emails (comma-separated)
ADMIN_EMAILS=shai@superseller.agency

# ============================================
# 🔒 SECURITY NOTES
# ============================================
# 1. Rotate ALL keys immediately after any exposure
# 2. Use different keys for development/staging/production
# 3. Store production keys in secure vault (Vercel, AWS Secrets Manager)
# 4. Never commit .env files to version control
# 5. Use strong, unique passwords for all services
