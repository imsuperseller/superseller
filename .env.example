# Rensto Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ============================================
# 🔐 AUTHENTICATION & SECURITY
# ============================================
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
DEFAULT_ADMIN_EMAIL=admin@rensto.com
DEFAULT_ADMIN_PASSWORD=generate-secure-password-here

# OAuth State Management
OAUTH_STATE_SECRET=generate-with-openssl-rand-base64-32

# Credential Encryption
CREDENTIAL_ENCRYPTION_KEY=generate-with-openssl-rand-hex-64

# ============================================
# 💳 PAYMENT INTEGRATIONS
# ============================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# QuickBooks OAuth
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_REDIRECT_URI=https://yourdomain.com/api/oauth/quickbooks-callback

# Credit-based gating (invoice.paid subscription resets)
CREDITS_PER_SUBSCRIPTION_CYCLE=500

# ============================================
# 🗄️ DATABASE & STORAGE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/rensto
AIRTABLE_PAT=pat...

# PostgreSQL (when migrating from Firebase – put real creds only in .env or Vault)
POSTGRES_USER=admin
POSTGRES_DB=app_db
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (when used – put real password only in .env or Vault)
REDIS_PASSWORD=your-redis-password-here
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# 🤖 AI & AUTOMATION
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# 📊 ANALYTICS & MONITORING
# ============================================
NOTION_API_TOKEN=secret_...

# ============================================
# 🌐 INFRASTRUCTURE
# ============================================
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_URL=https://your-n8n-instance.com

# ============================================
# 🔒 SECURITY NOTES
# ============================================
# 1. Rotate ALL keys immediately after any exposure
# 2. Use different keys for development/staging/production
# 3. Store production keys in secure vault (Vercel, AWS Secrets Manager)
# 4. Never commit .env files to version control
# 5. Use strong, unique passwords for all services
