# Rensto SaaS API - Production Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://localhost:27017/rensto-saas

# JWT Configuration
JWT_SECRET=rensto-production-super-secret-jwt-key-2025
JWT_EXPIRES_IN=7d

# Stripe Configuration (Production)
STRIPE_SECRET_KEY=sk_live_YOUR_PRODUCTION_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET

# Stripe Price IDs for Subscription Plans (Production)
STRIPE_BASIC_PRICE_ID=price_basic_plan_production_123456789
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_plan_production_123456789
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan_production_123456789

# Frontend URLs
FRONTEND_URL=https://rensto.com
ADMIN_URL=https://admin.rensto.com
PORTAL_URL=https://portal.rensto.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Security
CORS_ORIGIN=https://rensto.com,https://admin.rensto.com,https://portal.rensto.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
