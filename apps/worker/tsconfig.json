{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "module": "commonjs",
        "moduleResolution": "node"
    },
    "include": [
        "src/**/*",
        "remotion/src/types/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/**/*.test.ts",
        "src/__tests__/**",
        "src/scripts/**"
    ]
}