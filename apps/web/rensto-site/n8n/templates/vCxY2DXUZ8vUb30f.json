            ]
        },
        {
            "parameters": {
                "jsCode": "// CLIENT CONFIGURATION\nconst clients = [\n  {\n    client_name: 'Your Client Name',\n    client_slug: 'your-client-slug',\n    website_url: 'https://yourwebsite.com',\n    clarity_project_id: 'your_clarity_id',\n    ga4_property_id: 'your_ga4_id',\n    primary_conversion_event: 'purchase',\n    email_recipients: ['admin@example.com'],\n    slack_channel_id: 'C012345678',\n    active: true\n  }\n];\nreturn clients.filter(c => c.active).map(c => ({ json: c }));"
            },
            "id": "client-config",
            "name": "Client Config",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -384,
                128
            ]
        },
        {
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "// Get input data - in runOnceForEachItem mode, just use $json directly\nconst client = $json;\n\nconst now = new Date();\nconst startOfLastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);\nconst endOfLastMonth = new Date(now.getFullYear(), now.getMonth(), 0);\nconst formatDate = (d) => d.toISOString().split('T')[0];\nconst monthName = startOfLastMonth.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });\n\n// In runOnceForEachItem mode, return the object directly (not wrapped in [{json:...}])\nreturn {\n  client_name: client.client_name,\n  client_slug: client.client_slug,\n  website_url: client.website_url,\n  clarity_project_id: client.clarity_project_id,\n  ga4_property_id: client.ga4_property_id,\n  primary_conversion_event: client.primary_conversion_event,\n  email_recipients: client.email_recipients,\n  slack_channel_id: client.slack_channel_id,\n  notion_report_db_id: client.notion_report_db_id,\n  active: client.active,\n  dateRange: {\n    clarity: { numOfDays: 3 },\n    ga4: {\n      startDate: formatDate(startOfLastMonth),\n      endDate: formatDate(endOfLastMonth)\n    },\n    reportMonth: monthName\n  },\n  executionId: $execution.id\n};"
            },
            "id": "date-range",
            "name": "Calculate Date Range",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -160,
                128
