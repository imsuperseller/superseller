            "id": "clarity-api",
            "name": "Clarity API",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.3,
            "position": [
                48,
                32
            ]
        },
        {
            "parameters": {
                "jsCode": "// Merge Clarity and GA4 data with aggressive size limits\nconst items = $input.all();\nlet clarityData = items[0]?.json || {};\nlet ga4Data = items[1]?.json || {};\nconst clientConfig = $('Calculate Date Range').first().json;\n\n// Aggressively trim Clarity data - keep only first 20 rows\nif (clarityData.rows && clarityData.rows.length > 20) {\n  clarityData = { \n    totalRows: clarityData.rows.length,\n    rows: clarityData.rows.slice(0, 20), \n    trimmed: true \n  };\n}\n\n// Aggressively trim GA4 rows\nif (ga4Data.rows && ga4Data.rows.length > 15) {\n  ga4Data = { \n    totalRows: ga4Data.rows.length,\n    rows: ga4Data.rows.slice(0, 15), \n    trimmed: true \n  };\n}\n\nreturn [{\n  json: {\n    client_name: clientConfig.client_name,\n    client_slug: clientConfig.client_slug,\n    reportMonth: clientConfig.dateRange.reportMonth,\n    website: clientConfig.website_url,\n    clarity: clarityData,\n    ga4: ga4Data,\n    primary_conversion_event: clientConfig.primary_conversion_event,\n    notion_report_db_id: clientConfig.notion_report_db_id,\n    slack_channel_id: clientConfig.slack_channel_id,\n    email_recipients: clientConfig.email_recipients\n  }\n}];"
            },
