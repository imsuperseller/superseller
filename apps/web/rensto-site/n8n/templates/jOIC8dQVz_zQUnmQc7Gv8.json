                "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an ad-copy generator that creates Billy Mays / miracle kitchen gadget style prompt packs for KIE Video Agent. Emphasize time saved, reputation, control, predictable cost, fewer mistakes. Output valid JSON only with keys: agentVersion, workflowStepsSummary (array of strings), promptPacks (object with x_10s, tiktok_20s, li_fb_45s, youtube_180s).\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Create 4 prompt packs for this workflow. Each pack needs: platform, lengthSeconds, videoAgentPrompt, voiceoverScript, onScreenTextBeats (array), proofInsertion (object with assetUrl, label, durationMs), cta. Style: miracle gadget infomercial.\\n\\nWORKFLOW_NAME: {{ $json.normalizedForLLM.name }}\\nWORKFLOW_PAYLOAD: {{ JSON.stringify($json.normalizedForLLM.workflowPayload) }}\\nPROOF_ASSETS: {{ JSON.stringify($json.normalizedForLLM.proofAssets) }}\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}",
