        {
            "parameters": {
                "jsCode": "const crypto = require('crypto');\nconst input = $input.first().json;\n\nconst normalized = {\n  name: input.name ?? null,\n  workflowPayload: input.workflowPayload ?? null,\n  proofAssets: Array.isArray(input.proofAssets) ? input.proofAssets : []\n};\n\nconst stableStringify = (obj) => {\n  const allKeys = [];\n  JSON.stringify(obj, (k, v) => { allKeys.push(k); return v; });\n  allKeys.sort();\n  return JSON.stringify(obj, allKeys);\n};\n\nconst raw = stableStringify(normalized);\nconst hash = crypto.createHash('sha256').update(raw).digest('hex');\n\nreturn [{\n  json: {\n    ...input,\n    computedHash: hash,\n    normalizedForLLM: normalized\n  }\n}];"
            },
            "id": "692024b7-31ef-4e30-a956-9113b63d333b",
            "name": "Compute Payload Hash",
            "type": "n8n-nodes-base.code",
