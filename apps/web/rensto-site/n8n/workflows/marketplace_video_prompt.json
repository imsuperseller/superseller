                                "operation": "notEquals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "5594b610-d258-4e4f-9ebe-8620ff26d366",
            "name": "Hash Changed?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.3,
            "position": [
                2928,
                1728
            ]
        },
        {
            "parameters": {
                "jsCode": "const resp = $input.first().json;\nconst docId = $('Normalize Data').first().json.docId;\nconst computedHash = $('Compute Payload Hash').first().json.computedHash;\n\nlet content = resp.choices?.[0]?.message?.content;\nif (!content) {\n  throw new Error('No content in OpenAI response');\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(content);\n} catch (e) {\n  throw new Error('Failed to parse JSON: ' + e.message);\n}\n\nif (!parsed.promptPacks || !parsed.workflowStepsSummary) {\n  throw new Error('Missing required keys');\n}\n\nreturn [{ json: { \n  ...parsed, \n  docId, \n  computedHash, \n  status: 'done', \n  lastGeneratedAt: $now.toISO() \n} }];"
            },
