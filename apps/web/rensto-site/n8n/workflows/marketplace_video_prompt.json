                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "c-hash",
                            "leftValue": "={{ $json.computedHash }}",
                            "rightValue": "={{ $json.lastGeneratedHash }}",
                            "operator": {
