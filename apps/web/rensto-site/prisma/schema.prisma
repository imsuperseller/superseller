// Rensto Prisma Schema — Full PostgreSQL migration from Firestore
// Replaces ~35 Firestore collections with relational models
// JSON used for complex nested objects; proper columns for queried/filtered fields

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (stable, well-defined sets only)
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

enum BillingInterval {
  month
  year
}

// ==========================================
// GROUP 0: MULTI-TENANCY
// ==========================================

/// Multi-tenant business account.
model Tenant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String   @unique
  status         String   @default("active") // active, paused, closed
  
  plan           Json?    // PlanSchema shape
  settings       Json?    // { timezone, dateFormat, branding }
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          TenantUser[]
  
  @@index([slug])
  @@index([status])
}

/// Join table for User <-> Tenant many-to-many relationship
model TenantUser {
  tenantId String @db.Uuid
  userId   String @db.Uuid
  role     String @default("user") // owner, admin, user, viewer
  
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([tenantId, userId])
}

// ==========================================
// GROUP 1: AUTH & USER IDENTITY
// ==========================================

/// Primary user/client record. Standardized to native UUID.
model User {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String  @unique
  name           String?
  phone          String?
  image          String?
  dashboardToken String? @unique

  // Business Profile
  businessName String?
  businessType String? // 'hvac','realtor','restaurant','insurance', etc.
  businessSize String? // 'solo','small_team','medium_team'
  revenueRange String? // '$200k-500k','$500k-1m', etc.

  // Account Status
  status        String   @default("active")
  role          UserRole @default(USER)
  emailVerified DateTime?

  // Infrastructure (JSON — rarely queried individually)
  n8nInstance Json? // { url, apiKey, mcpToken }

  // Service Access flags
  activeServices Json? // { marketplace, whatsapp, subscriptions, custom_solutions, care_plan }

  // Entitlements (complex nested — engines, pillars, etc.)
  entitlements Json? // UserEntitlements shape

  // Billing
  stripeCustomerId       String?
  defaultPaymentMethodId String?
  billingAddress         Json? // { line1, line2, city, state, postalCode, country }

  // Preferences
  preferences Json? // { language, emailNotifications, smsNotifications, timezone }

  // Dashboard metrics (incremented by sync-usage bridge)
  metrics Json? // { totalLeads, totalMessages, totalBookings, lastActivityAt }

  // Acquisition
  source             String? // 'organic','referral','paid_ad','partner','qualification_quiz'
  referrerId         String?
  qualificationScore Int?
  qualificationTier  String? // 'high','medium','low'

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // ---- Relations ----
  tenants        TenantUser[]
  
  // NextAuth (future use)
  accounts Account[]
  sessions Session[]

  // App relations
  entitlement          Entitlement?
  usageEvents          UsageEvent[]
  magicLinkTokens      MagicLinkToken[]
  payments             Payment[]
  purchases            Purchase[]
  serviceInstances     ServiceInstance[]
  subscriptions        Subscription[]
  whatsappInstances    WhatsAppInstance[]
  leads                Lead[]
  usageLogs            UsageLog[]
  approvalRequests     ApprovalRequest[]
  supportCases         SupportCase[]
  carePlanDeliverables CarePlanDeliverable[]
  responseTimeMetrics  ResponseTimeMetrics[]
  contentPosts         ContentPost[]
  indexedDocuments     IndexedDocument[]
  secretaryConfigs     SecretaryConfig[]
  proposals            Proposal[]
  scorecards           Scorecard[]
  consultations        Consultation[]
  leadRequests         LeadRequest[]
  onboardingRequests   OnboardingRequest[]
  solutionInstances    SolutionInstance[]
  voiceCallLogs        VoiceCallLog[]
  outreachCampaigns    OutreachCampaign[]

  @@index([email])
  @@index([stripeCustomerId])
  @@index([dashboardToken])
  @@index([status])
}

/// NextAuth Account — kept for future OAuth integration
model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// NextAuth Session — kept for future OAuth integration
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// NextAuth VerificationToken — kept for future OAuth integration
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Custom magic-link authentication tokens
model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  clientId  String   @db.Uuid
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([clientId])
}

/// Legacy custom-solutions client record (backward compat during migration)
model CustomSolutionsClient {
  id    String @id @db.Uuid // same ID as User
  email String
  name  String

  websiteUrl String?

  qualificationScore Int    @default(0)
  qualificationTier  String @default("low")
  answers            Json? // Record<string, string>

  selectedTier String? // starter, professional, enterprise
  solutionPlan Json?

  stripeSessionId  String?
  stripeCustomerId String?
  amountPaid       Float?

  contractId     String?
  contractStatus String? // pending, signed, declined

  status String @default("qualified")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  @@index([email])
}

/// Legacy client branding record
model Client {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  logoUrl           String?
  showLogoOnLanding Boolean @default(false)
  privacySettings   Json? // { hideBusinessName, customLabel }
  hebrew            Json? // { name }
  status            String  @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testimonials Testimonial[]
}

// ==========================================
// GROUP 2: PAYMENTS & PURCHASES
// ==========================================

/// Stripe payment events logged from webhooks
model Payment {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String? @db.Uuid
  stripeSessionId  String?
  stripeCustomerId String? // Stripe customer ID (cus_xxx)
  customerId       String? // Legacy: Stripe customer ID alias
  customerEmail    String?
  amount           Int     @default(0) // cents (unified field name)
  amountTotal      Int     @default(0) // cents (legacy compat)
  currency         String  @default("usd")
  status           String  @default("pending") // pending, completed, failed, refunded
  flowType         String? // marketplace-template, managed-plan, pillar-purchase, etc.
  productId        String?
  tier             String?
  platform         String  @default("rensto-web")
  metadata         Json?   // Flexible metadata for any extra info

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([stripeSessionId])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([status])
}

/// Marketplace purchase records with secure download tokens
model Purchase {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String  @db.Uuid
  templateId      String?
  customerEmail   String
  stripeSessionId String?
  downloadToken   String?
  downloadUrl     String?
  tier            String?

  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([templateId])
  @@index([downloadToken])
}

/// Template download events
model Download {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId      String
  userEmail       String
  paymentIntentId String?
  status          String  @default("completed")
  userAgent       String? @db.Text
  ip              String?

  createdAt DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([userEmail])
}

// ==========================================
// GROUP 3: SERVICES & SUBSCRIPTIONS
// ==========================================

/// Active service instances (marketplace installs, Core 7, etc.)
model ServiceInstance {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String @db.Uuid
  clientEmail String
  productId   String?
  productName String?
  status      String @default("pending_setup") // pending_setup,configuring,provisioning,active,suspended,cancelled
  type        String? // marketplace_implementation, etc.

  configuration Json? // User answers to config schema

  // Administrative
  n8nWorkflowId   String?
  adminNotes      String?
  stripeSessionId String?

  // WhatsApp-specific
  whatsappInstanceId String? @db.Uuid
  whatsappBundle     String?

  // Performance
  speedToLeadAverage Float?
  leadsCaptured      Int?
  appointmentsBooked Int?

  // Legacy compat
  serviceId  String?
  parameters Json?

  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([productId])
  @@index([status])
}

/// Recurring subscriptions (WhatsApp, care plan, lead gen, content AI)
model Subscription {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @db.Uuid
  userEmail String

  // Stripe
  stripeSubscriptionId String?
  stripeCustomerId     String?
  stripePriceId        String?

  subscriptionType String // whatsapp, care_plan, lead_generation, content_ai

  // WhatsApp-specific
  whatsappBundle     String?
  whatsappInstanceId String? @db.Uuid

  // Care Plan-specific
  carePlanTier               String?
  carePlanDeliverablesSummary Json? // monthly summary snapshot

  // Lead Gen-specific
  leadGenTier   String?
  leadGenConfig Json? // { leadsPerMonth, sources, niche }

  // Pricing
  amount          Int             @default(0) // cents
  currency        String          @default("usd")
  billingInterval BillingInterval @default(month)

  // Status
  status             String    @default("active") // active,past_due,canceled,unpaid,trialing
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  // Usage tracking
  usageLimits  Json?
  currentUsage Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappInstances    WhatsAppInstance[]
  carePlanDeliverables CarePlanDeliverable[]
  leads                Lead[]

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@index([subscriptionType])
}

/// Monthly care plan deliverable tracking
model CarePlanDeliverable {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  subscriptionId String @db.Uuid
  carePlanTier   String // starter, growth, scale

  periodStart DateTime
  periodEnd   DateTime
  month       String // "2026-01"

  deliverables Json // Complex nested deliverables object

  hoursAllocated Float
  hoursUsed      Float @default(0)
  hoursRemaining Float

  status      String    @default("in_progress") // in_progress, completed, overdue
  completedAt DateTime?

  notes            String?
  customerFeedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([month])
}

/// Reusable service blueprints with pricing and n8n config
model ServiceManifest {
  id          String  @id
  name        String
  slug        String  @unique
  description String
  type        String // n8n_workflow, code_function
  active      Boolean @default(true)

  pricing Json // { subscription, setup } in cents
  n8n     Json // { webhookId, inputs }
  stripe  Json // { productId, priceId, setupPriceId }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// GROUP 4: MARKETPLACE & SOLUTIONS
// ==========================================

/// Marketplace template/product catalog
model Template {
  id          String  @id
  name        String
  description String? @db.Text
  category    String?
  price       Float   @default(0)

  installPrice Float?
  customPrice  Float?

  features Json? // string[] or Array<{ title, desc, image, icon }>

  installation    Boolean?
  popular         Boolean?
  version         String?
  readinessStatus String   @default("Draft") // Active, Draft, Internal
  partner         String?
  setupTime       String?
  targetMarket    String?
  demoVideo       String?
  previewImages   Json? // string[]
  downloadCount   Int      @default(0)
  image           String?
  video           String?
  rating          Float?
  tools           Json? // string[]
  content         String?  @db.Text
  tags            Json? // string[]
  outcomeHeadline String?

  // Deployment & Hebrew translations
  deploymentSteps    Json?
  name_he            String?
  description_he     String?  @db.Text
  outcomeHeadline_he String?
  features_he        Json?

  workflowId String?

  // Technical
  technicalRequirements Json? // FormField[]
  pricingConfig         Json? // { builder, bundle } — named to avoid SQL keyword

  // Ownership
  owner      String? // rensto, client
  clientId   String? @db.Uuid
  department String?

  // n8n Integration
  n8nWorkflowId  String?
  n8nWorkflowUrl String?

  // Stripe Integration
  stripeProductId String?
  stripePriceId   String?

  // Visibility
  showInMarketplace     Boolean @default(true)
  showInAdminDashboard  Boolean @default(true)
  showInClientDashboard Boolean @default(false)

  // Fulfillment
  configurationSchema Json? // FormField[]
  deliveryChecklist   Json? // string[]

  // Rich Content / Marketing
  complexity                String? // Beginner, Intermediate, Advanced
  businessImpact            String?
  businessImpact_he         String?
  roiExample                String?
  roiExample_he             String?
  oneTimeCost               Float?
  maintenanceCost           Float?
  maintenanceExplanation    String?
  maintenanceExplanation_he String?
  aiPromptScript            String? @db.Text
  soraVideoPrompt           String? @db.Text
  guarantee                 String?
  guarantee_he              String?
  isTargetTier              Boolean?

  integrations Json? // string[] — tools/apps this template integrates with
  metrics      Json? // { leads_per_month, time_saved, etc. }

  kpis         Json?
  kpis_he      Json?
  useCases     Json?
  useCases_he  Json?
  faqs         Json?
  faqs_he      Json?
  creator      Json?
  creator_he   Json?
  videoScripts Json?

  lastAuditedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  purchases             Purchase[]
  downloads             Download[]
  customizationRequests CustomizationRequest[]

  @@index([readinessStatus])
  @@index([category])
  @@index([owner])
}

/// Marketplace customization requests
model CustomizationRequest {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId    String
  customerEmail String?
  parameters    Json?   // Customization parameters from modal
  data          Json?   // Full request payload (legacy compat)
  status        String  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([customerEmail])
}

/// Solution catalog (Jan 2026 restructuring — outcome-focused products)
model Solution {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String? @db.Text
  outcomeHeadline String?
  category        String? // Leads, Creative, Operations, Strategy
  type            String? // marketplace-autoposter, voice-ai, etc.
  status          String  @default("active") // active, beta, coming_soon

  pricing Json? // { builder, bundle, maintenance }

  features           Json? // string[]
  tools              Json? // string[]
  video              String?
  image              String?
  tags               Json? // string[]
  rating             Float   @default(0)
  downloads          Int     @default(0)
  partner            String?
  technicalRequirements Json? // FormField[]
  workflowTemplateId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances SolutionInstance[]
}

/// Client-specific solution instance with deployment tracking
model SolutionInstance {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  solutionId  String @db.Uuid
  clientId    String @db.Uuid
  clientEmail String

  model  String @default("builder") // builder, bundle
  status String @default("pending_setup") // pending_setup,provisioning,active,error,maintenance

  configuration Json?
  technicalPulse Json? // { responseTime, stabilityScore, lastUpdateAt }
  deploymentLog  Json? // Array<{ step, message, timestamp }>

  n8nWorkflowId        String?
  stripeSubscriptionId String?

  lastRunAt  DateTime?
  lastStatus String? // success, error
  errorCount Int     @default(0)

  provisionedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  solution Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([solutionId])
  @@index([clientId])
  @@index([status])
}

// ==========================================
// GROUP 5: WHATSAPP AI
// ==========================================

/// WhatsApp AI agent instances per customer
model WhatsAppInstance {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String  @db.Uuid
  userEmail    String
  businessName String?
  businessType String?

  phoneNumber    String?
  wahaInstanceId String?
  n8nWorkflowId  String?

  bundle         String? // never_miss_lead, auto_qualify_book, full_ai_sales_rep, etc.
  bundleFeatures Json? // Feature flags object
  addOns         Json?

  status        String @default("pending_setup") // pending_setup,provisioning,active,suspended,cancelled
  metrics       Json? // { totalMessages, averageResponseTime, leadsCaptured, ... }
  configuration Json? // { businessHours, serviceAreas, pricing, calendarIntegration, ... }

  subscriptionId String? @db.Uuid
  carePlanId     String? @db.Uuid

  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  messages WhatsAppMessage[]
  bookings AppointmentBooking[]
  leads    Lead[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

/// Individual WhatsApp messages with speed-to-lead tracking
model WhatsAppMessage {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whatsappInstanceId String @db.Uuid
  userId             String @db.Uuid

  from        String
  to          String
  messageType String // text, image, video, audio, document, location
  content     String? @db.Text
  direction   String // inbound, outbound

  responseTime      Float?
  isFirstContact    Boolean @default(false)
  firstResponseTime Float?

  leadStatus        String?
  qualificationData Json?
  appointmentBooked Json?

  escalatedToHuman Boolean   @default(false)
  escalatedAt      DateTime?
  humanRespondedAt DateTime?

  sessionId String?
  metadata  Json?

  createdAt DateTime @default(now())

  whatsappInstance WhatsAppInstance @relation(fields: [whatsappInstanceId], references: [id], onDelete: Cascade)

  @@index([whatsappInstanceId])
  @@index([userId])
  @@index([createdAt])
}

/// Appointments booked through WhatsApp AI
model AppointmentBooking {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whatsappInstanceId String @db.Uuid
  userId             String @db.Uuid

  customerName  String
  customerPhone String
  customerEmail String?

  serviceType     String?
  appointmentDate DateTime
  appointmentTime String?
  duration        Int? // minutes
  location        String?

  status         String    @default("scheduled") // scheduled,confirmed,completed,cancelled,no_show
  confirmedAt    DateTime?
  reminderSent   Boolean   @default(false)
  reminderSentAt DateTime?

  calendarEventId  String?
  calendarProvider String? // tidycal, calendly, google

  source            String  @default("whatsapp_ai") // whatsapp_ai, manual, website, phone
  whatsappMessageId String? @db.Uuid

  notes         String? @db.Text
  internalNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappInstance WhatsAppInstance @relation(fields: [whatsappInstanceId], references: [id], onDelete: Cascade)

  @@index([whatsappInstanceId])
  @@index([userId])
  @@index([appointmentDate])
  @@index([status])
}

// ==========================================
// GROUP 6: LEADS & OUTREACH
// ==========================================

/// Lead records from all sources with speed-to-lead and conversion tracking
model Lead {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  source   String // whatsapp, linkedin, google_maps, facebook, apify, manual, qualification_quiz
  sourceId String?

  userId             String @db.Uuid
  subscriptionId     String? @db.Uuid
  whatsappInstanceId String? @db.Uuid

  // Contact info
  name    String?
  company String?
  email   String?
  phone   String?
  website String?
  location Json? // { city, state, country, zipCode }

  // Speed-to-Lead
  firstContactAt     DateTime?
  firstResponseAt    DateTime?
  responseTime       Float?
  responseTimeStatus String? // excellent, good, poor

  // Qualification
  qualificationStatus String @default("unqualified") // unqualified, qualified, high_priority
  qualificationData   Json?
  enrichedData        Json?

  // CRM Status
  status          String    @default("new") // new, contacted, qualified, quoted, converted, lost
  statusUpdatedAt DateTime?

  // Delivery
  deliveredAt    DateTime?
  deliveryMethod String? // whatsapp, email, api, webhook, dashboard, crm

  // Conversion
  convertedAt      DateTime?
  conversionValue  Float?
  conversionSource String?

  // Metadata
  tags     Json? // string[]
  notes    String? @db.Text
  metadata Json?

  syncedToAITable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  whatsappInstance WhatsAppInstance? @relation(fields: [whatsappInstanceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

/// Free-leads trial requests
model LeadRequest {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid
  data   Json? // Full request payload
  status String @default("pending")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Email / LinkedIn / multi-channel outreach campaigns
model OutreachCampaign {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String  @db.Uuid
  name   String?
  type   String? // email, linkedin, etc.
  status String  @default("draft")
  data   Json? // Campaign details
  metrics Json? // Campaign performance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Monthly response-time analytics per user
model ResponseTimeMetrics {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String @db.Uuid
  whatsappInstanceId String? @db.Uuid
  subscriptionId     String? @db.Uuid

  period      String // "2026-01"
  periodStart DateTime
  periodEnd   DateTime

  totalLeads          Int   @default(0)
  averageResponseTime Float @default(0)
  medianResponseTime  Float @default(0)

  responseTimeBuckets Json // { under5min, under30min, over30min }
  conversionsBySpeed  Json // { under5min: {...}, under30min: {...}, over30min: {...} }

  targetResponseTime Float   @default(300)
  goalMet            Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([period])
}

// ==========================================
// GROUP 7: DASHBOARD & CONTENT
// ==========================================

/// Agent execution logs (n8n runs, AI calls, etc.)
model UsageLog {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId String @db.Uuid
  userId   String? @db.Uuid // alias for clientId (used by billing queries)
  agentId  String  @default("system") // matches ServiceManifest.id
  status   String  @default("completed") // completed, failed, running

  serviceType String? // General AI, Lead Machine, WhatsApp, etc.
  tokenCount  Int?    // total tokens consumed (simple counter)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  model  String? // gpt-4-turbo, etc.
  tokens Json? // { input, output, total }
  cost   Float  @default(0) // cents

  output   String? @db.Text
  metadata Json?

  clientEmail String? // for billing queries by email

  user User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([agentId])
  @@index([clientEmail])
  @@index([startedAt])
  @@index([status])
}

/// Blog posts and social content
model ContentPost {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String  @db.Uuid
  title  String?
  content String? @db.Text
  type   String? // blog, social, etc.
  status String  @default("draft")
  slug   String?
  platform String? // blog, linkedin, twitter, etc.

  metadata Json?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slug])
  @@index([status])
  @@index([type])
}

/// Knowledge-base indexed documents (PDF, URL, text)
model IndexedDocument {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId String @db.Uuid
  name     String
  type     String // pdf, url, text
  status   String @default("processing") // indexed, processing, failed

  url      String?
  size     String?
  metadata Json?

  indexedAt  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

/// Voice / WhatsApp AI secretary configuration per client
model SecretaryConfig {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String  @db.Uuid
  agentName       String?
  voiceId         String?
  greeting        String? @db.Text
  tone            String?
  businessContext String? @db.Text

  phoneNumber    String?
  transferNumber String?
  n8nWebhookId   String?

  whatsappEnabled Boolean @default(false)
  calendarEnabled Boolean @default(false)
  calendarLink    String?

  availability Json? // { enabled, hours }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([phoneNumber])
  @@index([n8nWebhookId])
}

/// Voice call log entries
model VoiceCallLog {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid
  data   Json // Full call log payload

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ==========================================
// GROUP 8: ADMIN, SUPPORT & MISC
// ==========================================

/// Customer support cases with AI reasoning
model SupportCase {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId       String  @db.Uuid
  workflowId       String?
  carePlanTier     String?
  submissionMethod String? // magic_button, voice, whatsapp
  issueDescription String  @db.Text

  contextData Json? // { recentErrors, workflowJson, capturedAt }

  status         String @default("pending") // pending,researching,fixing,testing,awaiting_approval,resolved,escalated
  aiReasoningLog Json? // string[]
  attemptCount   Int    @default(0)

  proposedFix Json? // { diff, testResult, confidence }
  resolution  Json? // { approved, feedback, resolvedAt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
}

/// Content / workflow approval requests
model ApprovalRequest {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String  @db.Uuid
  serviceId   String
  title       String
  description String? @db.Text
  content     Json? // structured content to approve

  status String @default("pending") // pending, approved, rejected

  requestedAt DateTime  @default(now())
  respondedAt DateTime?
  feedback    String?   @db.Text
  expiresAt   DateTime?

  user User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

/// Client testimonials (linked to legacy Client model)
model Testimonial {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId String? @db.Uuid
  language String  @default("en") // en, he

  // Core fields (used by admin CRUD)
  name     String? // Display name (alias for author)
  author   String? // Legacy: author name
  role     String?
  company  String?
  content  String? @db.Text // Testimonial text (alias for quote)
  quote    String? @db.Text // Legacy: testimonial text
  result   String?
  rating   Float?
  avatar   String? // Profile image URL
  imageUrl String?
  label    String?
  order    Int     @default(0)
  isActive Boolean @default(true)

  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([isActive])
}

/// Onboarding form submissions for solution setup
model OnboardingRequest {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String  @db.Uuid
  solutionId String? @db.Uuid
  status     String  @default("draft") // draft, submitted, approved, rejected
  data       Json? // Full form data

  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

/// System audit trail
model Audit {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service      String
  action       String
  status       String // success, error
