}

/// Admin AI assistant (Terry) chat history
model AdminConversation {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messages Json // Array of { role, content, timestamp }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// n8n agent persistent memory store
model N8nAgentMemory {
  id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key  String?
  data Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

/// User account entitlements (credits, usage limits)
/// SSOT: Aligned with Drizzle entitlementsTable and CreditService
model Entitlement {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @unique @db.Uuid @map("user_id")
  creditsBalance Int       @default(0) @map("credits_balance") // unit-based (e.g. 1000 = 1000 credits)
  plan           String    @default("starter")
  status         String    @default("active")
  resetAt        DateTime? @map("reset_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("entitlements")
}

/// Precise usage events for auditing and billing
/// SSOT: Aligned with Drizzle usageEvents and CreditService
model UsageEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  type      String   // debit, refund, topup, grant, reset
  amount    Int      // Positive for topup/refund, negative for debit
  jobId     String?  @db.Uuid @map("job_id")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("usage_events")
}

/// Generic analytics events
model Analytics {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type   String
  data   Json
  period String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([period])
}

/// Industry niche definitions with WhatsApp FAQ templates
model BusinessNiche {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  slug     String @unique
  category String // home_services, professional_services, retail, food_service, other

  painPoints     Json? // string[]
  commonServices Json? // string[]

  typicalRevenue   String?
  typicalEmployees String?

  whatsappFaqs Json? // Array<{ question, answer }>

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

/// Encrypted secrets vault (replaces Firestore restricted/{sub}/items)
model VaultItem {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category String // The subcollection name
  key      String
  value    String @db.Text // Encrypted value
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key])
  @@index([category])
}
