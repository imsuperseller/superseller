}

/// Custom-solution consultation records
model Consultation {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String  @db.Uuid
  clientId String? @db.Uuid // alias for userId (used in proposals)
  type     String? // proposal, discovery_call, etc.
  data     Json? // Full consultation payload
