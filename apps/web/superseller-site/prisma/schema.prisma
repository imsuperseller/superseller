/// DB-driven prompt configuration — update prompts without code deploys.
/// Services: "videoforge", "marketplace", "claudeclaw", "socialhub"
/// Falls back to hardcoded prompts when DB is unavailable.
model PromptConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service   String   @db.VarChar(100)
  promptKey String   @map("prompt_key") @db.VarChar(200)
  template  String   @db.Text
  version   Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([service, promptKey, version], name: "prompt_config_service_key_version")
  @@index([service, promptKey], name: "idx_prompt_config_lookup")
  @@map("prompt_configs")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

enum BillingInterval {
  month
  year
}

// ═══════════════════════════════════════════════════════════════
// PROJECT + AUDIT SYSTEM (Admin Command Center)
// ═══════════════════════════════════════════════════════════════

/// A tracked unit of work — internal project, customer engagement, infra initiative, or external repo/site.
model Project {
  id              String    @id @default(cuid())
  name            String
  description     String?
  /// internal | customer | infrastructure | external
  type            String    @default("internal")
  /// planning | in_progress | verification | completed | blocked
  status          String    @default("planning")
  /// 0–100
  progress        Int       @default(0)
  /// business pillar label (e.g. "Marketplace", "VideoForge", "Infrastructure")
  pillar          String?
  owner           String?
  githubRepo      String?
  vercelProjectId String?
  startDate       DateTime?
  dueDate         DateTime?
  /// Free-form JSON for external IDs, tags, or phase-specific metadata
  metadata        Json?
  outlookEventId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  milestones         ProjectMilestone[]
  tasks              ProjectTask[]
  auditInstances     AuditInstance[]
  serviceInstances   ServiceInstance[]  @relation("ServiceInstanceProject")
  whatsAppInstances  WhatsAppInstance[] @relation("WhatsAppInstanceProject")
  ciRuns             CiRun[]

  @@index([type])
  @@index([status])
}

/// A named checkpoint within a Project.
model ProjectMilestone {
  id        String    @id @default(cuid())
  projectId String
  title     String
  dueDate   DateTime?
  /// pending | complete | overdue
  status    String    @default("pending")
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// An actionable task within a Project.
model ProjectTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  /// todo | in_progress | done | blocked
  status      String   @default("todo")
  assignee    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Defines a reusable playbook — e.g. "SuperSeller New Business Audit" or "Rensto City Launch".
model AuditTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  version     String         @default("1.0")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt

  sections    AuditSection[]
  instances   AuditInstance[]
}

/// A section within an AuditTemplate (e.g., "Business Fundamentals").
model AuditSection {
  id         String        @id @default(cuid())
  templateId String
  title      String
  order      Int           @default(0)
  createdAt  DateTime      @default(now())

  template   AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items      AuditItem[]

  @@index([templateId])
}

/// A single question or checklist item within an AuditSection.
model AuditItem {
  id          String         @id @default(cuid())
  sectionId   String
  question    String
  /// Freeform hint to help the responder answer
  hint        String?
  /// Optional: maps to a SuperSeller product for auto-suggest (Phase 6+)
  productTag  String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())

  section     AuditSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  responses   AuditResponse[]

  @@index([sectionId])
}

/// One run of an AuditTemplate for a specific Project/customer.
model AuditInstance {
  id         String         @id @default(cuid())
  templateId String
  projectId  String?
  /// Label for this engagement (e.g. "UAD Onboarding — March 2026")
  label      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @default(now()) @updatedAt

  template   AuditTemplate  @relation(fields: [templateId], references: [id])
  project    Project?       @relation(fields: [projectId], references: [id])
  responses  AuditResponse[]

  @@index([templateId])
  @@index([projectId])
}

/// One answer to one AuditItem within an AuditInstance.
model AuditResponse {
  id         String        @id @default(cuid())
  instanceId String
  itemId     String
  /// pending | complete | na
  status     String        @default("pending")
  answer     String?
  notes      String?
  updatedAt  DateTime      @default(now()) @updatedAt

  instance   AuditInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  item       AuditItem     @relation(fields: [itemId], references: [id])

  @@unique([instanceId, itemId])
  @@index([instanceId])
}

// ─── CI Pipeline ───

model CiRun {
  id          String   @id @default(cuid())
  projectId   String?
  repo        String
  branch      String   @default("main")
  commitSha   String
  commitMsg   String?
  status      String   @default("pending") /// pending | running | passed | failed
  duration    Int?     /// seconds
  typeCheck   String?  /// passed | failed | skipped
  lint        String?  /// passed | failed | skipped
  build       String?  /// passed | failed | skipped
  testCount   Int?
  failCount   Int?
  errorLog    String?
  workflowUrl String?
  triggeredBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  project     Project? @relation(fields: [projectId], references: [id])

  @@index([repo, branch])
  @@index([projectId])
  @@index([createdAt])
}

/// Review request — sent to clients after appointments to collect Google/Yelp reviews.
/// Flow: appointment done → API call → 2hr delayed send via WhatsApp + email.
model ReviewRequest {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantSlug   String    @map("tenant_slug")
  businessName String    @map("business_name")

  // Client info
  clientName  String  @map("client_name")
  clientPhone String? @map("client_phone")
  clientEmail String? @map("client_email")

  // Review links
  googleReviewUrl String? @map("google_review_url")
  yelpReviewUrl   String? @map("yelp_review_url")

  // Scheduling
  scheduledFor DateTime  @map("scheduled_for")
  status       String    @default("pending") // pending, sent, failed, cancelled
  sentAt       DateTime? @map("sent_at")

  // Delivery tracking
  whatsappSent Boolean @default(false) @map("whatsapp_sent")
  emailSent    Boolean @default(false) @map("email_sent")
  errorLog     String? @map("error_log")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status, scheduledFor])
  @@index([tenantSlug])
  @@map("review_requests")
}

// ═══════════════════════════════════════════════════════════════
// LANDING PAGE ANALYTICS
// ═══════════════════════════════════════════════════════════════

/// Individual page view event with metadata for analytics dashboard.
model PageView {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   // landing page slug
  referrer  String?  // document.referrer
  utmSource String?  @map("utm_source")
  utmMedium String?  @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  userAgent String?  @map("user_agent")
  ipHash    String?  @map("ip_hash") // SHA-256 hash, not raw IP
  country   String?
  device    String?  // "mobile" | "desktop" | "tablet"
  createdAt DateTime @default(now()) @map("created_at")

  @@index([slug, createdAt])
  @@index([slug])
  @@map("page_views")
}

/// Conversion events: form submissions, WhatsApp clicks, phone clicks, etc.
model ConversionEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   // landing page slug
  eventType String   @map("event_type") // "form_submit" | "whatsapp_click" | "phone_click" | "cta_click"
  metadata  Json?    // extra data (e.g. which CTA, form field values)
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([slug, createdAt])
  @@index([slug, eventType])
  @@map("conversion_events")
}

// ═══════════════════════════════════════════════════════════════
// CAPABILITY ENGINE
// ═══════════════════════════════════════════════════════════════

/// Platform capability registry — every feature, tool, agent, mechanism as a reusable block.
model Capability {
  id           String   @id @default(cuid())
  name         String   @unique            // e.g. "whatsapp-poll-approval"
  displayName  String                       // e.g. "WhatsApp Poll Approval"
  description  String?
  /// social | content | automation | analytics | infrastructure
  category     String
  /// feature | tool | agent | mechanism | integration
  type         String
  /// active | beta | deprecated
  status       String   @default("active")
  configSchema Json?                       // JSON Schema for per-entity config
  dependencies String[]                    // other capability names this depends on
  filePaths    String[]                    // key source files implementing this
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  entityCapabilities EntityCapability[]

  @@index([category])
  @@index([status])
}

/// Per-tenant capability activation status and config.
model EntityCapability {
  id            String    @id @default(cuid())
  capabilityId  String
  tenantId      String?   @db.Uuid          // null = global (SuperSeller itself)
  /// enabled | eligible | blocked | not_applicable
  status        String    @default("eligible")
  blockedReason String?
  config        Json?                       // entity-specific config for this capability
  enabledAt     DateTime?
  enabledBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([capabilityId, tenantId])
  @@index([tenantId])
  @@index([capabilityId])
}

// ===========================================================================
// Tenant Site Configuration — DB-driven contractor/business sites
// ===========================================================================

/// Full site configuration for a tenant's business website.
/// Replaces static .ts config files — single source of truth.
model TenantSiteConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique @db.Uuid
  phone           String
  email           String?
  addressStreet   String
  addressCity     String
  addressState    String
  addressZip      String
  website         String?
  foundedYear     Int?
  license         String?
  schemaType      String   @default("GeneralContractor") // JSON-LD schema type

  // Brand overrides (complements Brand model for site-specific colors)
  accentHoverColor String?
  backgroundColor  String?  @default("#FFFFFF")
  backgroundAlt    String?  @default("#F7F8FA")
  warmBg           String?  @default("#FDF8F3")
  textDark         String?  @default("#1E293B")
  textMid          String?  @default("#475569")
  textLight        String?  @default("#64748B")
  borderColor      String?  @default("#E2E8F0")

  // Content
  heroHeadline     String?
  heroSubheadline  String?
  aboutText        String?  @db.Text
  uniqueValue      String?

  // Hero media
  heroImageUrl     String?

  // SEO
  metaTitle        String?
  metaDescription  String?  @db.Text

  // Social links
  facebookUrl      String?
  instagramUrl     String?
  yelpUrl          String?
  tiktokUrl        String?
  youtubeUrl       String?
  googleReviewUrl  String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Related data
  trustBadges     TenantTrustBadge[]
  stats           TenantStat[]
  reviewPlatforms TenantReviewPlatform[]
}

/// Service offered by a tenant (e.g., Kitchen Remodeling).
model TenantService {
  id               String   @id @default(cuid())
  tenantId         String   @db.Uuid
  slug             String
  name             String
  shortDescription String
  longDescription  String?  @db.Text
  icon             String   @default("🔨")
  features         Json?    // String[] — stored as JSON array
  priceRange       String?
  imageUrl         String?
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

/// Geographic service area for a tenant.
model TenantServiceArea {
  id        String   @id @default(cuid())
  tenantId  String   @db.Uuid
  name      String   // City name (e.g., "Plano")
  state     String?  // State code (e.g., "TX")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Trust badge / credential for a tenant (e.g., "Licensed & Insured").
model TenantTrustBadge {
  id           String @id @default(cuid())
  siteConfigId String
  label        String
  detail       String?
  icon         String @default("✅")
  order        Int    @default(0)

  siteConfig TenantSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId])
}

/// Key statistic for a tenant (e.g., "15+ Years").
model TenantStat {
  id           String @id @default(cuid())
  siteConfigId String
  value        String
  label        String
  order        Int    @default(0)

  siteConfig TenantSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId])
}

/// Review platform presence for a tenant (e.g., Yelp 5.0/33).
model TenantReviewPlatform {
  id           String  @id @default(cuid())
  siteConfigId String
  name         String
  rating       Float
  count        Int
  url          String?
  order        Int     @default(0)

  siteConfig TenantSiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@index([siteConfigId])
}

// ===========================================================================
// Asset Registry — tracks all R2/external assets per tenant
// ===========================================================================

/// Centralized asset registry. Every file (logo, photo, video, character ref)
/// gets a DB record with its R2 key and metadata.
model TenantAsset {
  id          String   @id @default(cuid())
  tenantId    String   @db.Uuid
  type        String   // logo | photo | video | character_ref | before_after | document
  filename    String
  r2Key       String   @unique
  r2Bucket    String   @default("superseller-assets")
  publicUrl   String
  mimeType    String?
  sizeBytes   Int?
  metadata    Json?    // Flexible: { category, tags, description, beforeAfter: true }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type])
}

// ===========================================================================
// Pipeline Runs — unified execution tracking across all products
// ===========================================================================

/// Every generation (video, social post, review response) is a pipeline run.
/// Unified cost tracking, status, and delivery tracking.
model PipelineRun {
  id            String    @id @default(cuid())
  tenantId      String?   @db.Uuid
  pipelineType  String    // video | social_post | review_response | content | research
  status        String    @default("queued") // queued | running | completed | failed | cancelled
  inputJson     Json?     // What was requested
  outputJson    Json?     // What was produced (URLs, metadata)
  modelUsed     String?   // e.g., "kling-3.0", "claude-sonnet-4-6", "sora-2"
  costCents     Int?      // Total cost in cents
  deliveredVia  String?   // whatsapp | email | dashboard | api
  deliveredAt   DateTime?
  errorMessage  String?   @db.Text
  durationMs    Int?      // Processing time
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([pipelineType])
  @@index([status])
  @@index([createdAt])
}

/// Character Bible — reusable AI character identity for video/content pipelines.
/// Stores persona description, visual style, reference media, and approval status.
model CharacterBible {
  id                 String    @id @default(cuid())
  tenantId           String    @db.Uuid
  name               String                           // Character name (e.g., "Nick the Builder")
  personaDescription String?   @db.Text               // Full persona prompt for AI models
  visualStyle        String?                          // Visual style notes
  soraHandle         String?                          // Sora 2 @handle for cameos
  referenceVideoUrls Json?                            // String[] — reference videos
  testSceneUrls      Json?                            // String[] — test scene renders
  approvedAt         DateTime?
  approvedBy         String?
  version            Int       @default(1)
  active             Boolean   @default(true)
  metadata           Json?                            // Flexible: { voiceId, modelPreference, etc. }
  changeDelta        Json?                            // Diff from previous version: { rollback?, fields?, changeRequestId? }
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Idempotency table for payment webhook events — prevents duplicate processing.
model WebhookEvent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     String    // "paypal" or "stripe"
  eventId      String    // Provider's event ID (event.id for Stripe, event.id for PayPal)
  eventType    String    // e.g., "checkout.session.completed", "BILLING.SUBSCRIPTION.ACTIVATED"
  status       String    @default("processing") // "processing", "completed", "failed"
  payload      Json?     // Raw event payload for debugging
  errorMessage String?
  retryCount   Int       @default(0)
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([status])
}
