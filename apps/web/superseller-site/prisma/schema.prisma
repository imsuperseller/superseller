/// Customer-branded landing pages for lead generation. One template, per-customer branding.
/// Each page lives at /lp/[slug]. Leads from submissions are stored in the Lead model
/// with source="landing_page" and sourceId=slug.
model LandingPage {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String
  slug   String  @unique
  active Boolean @default(true)

  // Content
  heroHeadline    String
  heroSubheadline String?
  ctaText         String
  sections        Json?

  // Contact (Can override Brand or be specific to LP)
  whatsappNumber String?
  phone          String?
  email          String?

  // Settings
  direction String @default("rtl")
  locale    String @default("he")

  // Design Tokens
  theme              String  @default("dark") // "dark", "light", "glass"
  style              String  @default("modern") // "modern", "corporate", "creative", "minimal"
  fontHeading        String? // Google Font name, e.g. "Inter", "Playfair Display"
  fontBody           String? // Google Font name for body text
  animationSpeed     String  @default("normal") // "none", "subtle", "normal", "dramatic"
  heroStyle          String  @default("split") // "split", "fullwidth", "video", "parallax"
  cardStyle          String  @default("glass") // "glass", "solid", "outline", "elevated"
  sectionAlternation Boolean @default(true) // alternate bg colors between sections
  heroMediaUrl       String? // hero background image/video URL

  // SEO
  metaTitle       String?
  metaDescription String?

  // Analytics
  views       Int @default(0)
  submissions Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  brandId String? // References Brand.id (String)
  brand   Brand?  @relation(fields: [brandId], references: [id])

  @@map("landing_pages")
}

/// Marketplace customer profile (1 per user, manages multiple products)
model MarketplaceCustomer {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  businessName String    @map("business_name")
  subscription String?   @default("TRIAL")
  credits      Int?      @default(100)
  status       String?   @default("ACTIVE")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  products MarketplaceProduct[]
  posts    MarketplacePost[]
  sessions FacebookSession[]

  @@unique([userId])
  @@map("marketplace_customers")
}

/// FB Marketplace product (UAD doors, bounce houses, etc.)
model MarketplaceProduct {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  productType String    @map("product_type")
  name        String
  status      String?   @default("ACTIVE")
  config      Json
  pricing     Json
  schedule    Json?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  customer MarketplaceCustomer @relation(fields: [customerId], references: [id])
  posts    MarketplacePost[]

  @@map("marketplace_products")
}

/// GoLogin/Facebook session per product
model FacebookSession {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  productId  String    @map("product_id") @db.Uuid
  profileId  String    @map("profile_id")
  cookies    String
  status     String?   @default("ACTIVE")
  lastUsed   DateTime? @map("last_used") @db.Timestamp(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  customer MarketplaceCustomer @relation(fields: [customerId], references: [id])

  @@unique([customerId, productId])
  @@map("facebook_sessions")
}

/// FB Marketplace post record
model MarketplacePost {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId         String    @map("customer_id") @db.Uuid
  productId          String    @map("product_id") @db.Uuid
  status             String?   @default("queued")
  facebookUrl        String?   @map("facebook_url")
  configData         Json?     @map("config_data")
  imageUrl           String?   @map("image_url")
  imageUrl2          String?   @map("image_url2")
  imageUrl3          String?   @map("image_url3")
  videoUrl           String?   @map("video_url")
  listingTitle       String?   @map("listing_title")
  listingDescription String?   @map("listing_description")
  price              Decimal?  @db.Decimal
  location           String?
  phoneNumber        String?   @map("phone_number")
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  postedAt           DateTime? @map("posted_at") @db.Timestamp(6)

  customer MarketplaceCustomer @relation(fields: [customerId], references: [id])
  product  MarketplaceProduct  @relation(fields: [productId], references: [id])

  @@map("marketplace_posts")
}

/// AI model registry — every model from every provider with structured queryable fields.
/// The pipeline does: SELECT * FROM ai_models WHERE supports_start_end_frame AND category = 'video' ORDER BY cost_per_5s_usd
model AIModel {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider                 String
  model_name               String
  model_id                 String
  model_family             String?
  version                  String?
  release_date             DateTime? @db.Timestamptz(6)
  developer                String?
  category                 String
  subcategory              String?
  kie_endpoint             String?
  kie_model_param          String?
  fal_endpoint             String?
  direct_api_url           String?
  cost_per_second_usd      Float?
  cost_per_5s_usd          Float?
  cost_per_10s_usd         Float?
  cost_per_image_usd       Float?
  cost_per_minute_usd      Float?
  cost_per_1m_input_usd    Float?
  cost_per_1m_output_usd   Float?
  cost_per_call_usd        Float?
  pricing_notes            String?
  pricing_source           String?
  pricing_verified_at      DateTime? @db.Timestamptz(6)
  supports_image_to_video  Boolean?  @default(false)
  supports_text_to_video   Boolean?  @default(false)
  supports_start_end_frame Boolean?  @default(false)
  supports_multi_shot      Boolean?  @default(false)
  supports_native_audio    Boolean?  @default(false)
  supports_character_ref   Boolean?  @default(false)
  supports_elements        Boolean?  @default(false)
  supports_lip_sync        Boolean?  @default(false)
  supports_video_to_video  Boolean?  @default(false)
  supports_inpainting      Boolean?  @default(false)
  supports_upscale         Boolean?  @default(false)
  supports_compositing     Boolean?  @default(false)
  supports_face_swap       Boolean?  @default(false)
  supports_image_edit      Boolean?  @default(false)
  max_resolution           String?
  max_duration_sec         Int?
  min_duration_sec         Int?
  output_formats           String[]  @default([])
  max_upscale_factor       Int?
  max_input_images         Int?
  quality_overall          Int?
  quality_realism          Int?
  quality_motion           Int?
  quality_consistency      Int?
  quality_architecture     Int?
  speed_score              Int?
  real_estate_score        Int?
  best_for_rooms           String[]  @default([])
  walkthrough_notes        String?
  used_in_pipeline         Boolean?  @default(false)
  pipeline_role            String?
  env_var_to_enable        String?
  fallback_for             String?
  status                   String?   @default("active")
  capabilities             Json?
  benchmarks               Json?
  raw_pricing_data         Json?
  discovered_at            DateTime? @default(now()) @db.Timestamptz(6)
  last_checked             DateTime? @default(now()) @db.Timestamptz(6)
  last_price_change        DateTime? @db.Timestamptz(6)
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @default(now()) @db.Timestamptz(6)

  @@map("ai_models")
}

/// Best model per use case — auto-updated by daily sync
model AIModelRecommendation {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  use_case             String
  recommended_model_id String    @db.Uuid
  fallback_model_id    String?   @db.Uuid
  reasoning            String
  cost_per_unit        Float?
  quality_score        Float?
  speed_ms             Int?
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)

  @@map("ai_model_recommendations")
}

/// Decision audit log — tracks every model selection
model AIModelDecision {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  use_case                String
  chosen_model_id         String    @db.Uuid
  alternatives_considered String[]  @default([])
  reasoning               String
  created_at              DateTime? @default(now()) @db.Timestamptz(6)
  created_by              String?   @db.Uuid

  @@map("ai_model_decisions")
}

/// DB-driven prompt configuration — update prompts without code deploys.
/// Services: "videoforge", "marketplace", "claudeclaw", "socialhub"
/// Falls back to hardcoded prompts when DB is unavailable.
model PromptConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service   String   @db.VarChar(100)
  promptKey String   @map("prompt_key") @db.VarChar(200)
  template  String   @db.Text
  version   Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([service, promptKey, version], name: "prompt_config_service_key_version")
  @@index([service, promptKey], name: "idx_prompt_config_lookup")
  @@map("prompt_configs")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

enum BillingInterval {
  month
  year
}
