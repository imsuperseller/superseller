generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Multi-tenant business account.
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  status    String   @default("active")
  plan      Json?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  brand              Brand?
  leads              Lead[]
  competeAllowlist   CompeteAllowlist[]
  entityCapabilities EntityCapability[]
  services           TenantService[]
  serviceAreas       TenantServiceArea[]
  assets             TenantAsset[]
  pipelineRuns       PipelineRun[]
  siteConfig         TenantSiteConfig?
  characterBibles    CharacterBible[]
}

/// Emails allowed to request magic links for a tenant's Compete page (whitelist).
model CompeteAllowlist {
  id        String   @id @default(cuid())
  tenantId  String   @db.Uuid
  email     String
  addedAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// Centralized brand identity and configuration
model Brand {
  id             String   @id @default(cuid())
  tenantId       String?  @unique @db.Uuid
  userId         String?
  name           String
  slug           String   @unique
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#1e3a8a")
  accentColor    String   @default("#2563eb")
  ctaColor       String   @default("#f97316")
  fontFamily     String   @default("Inter")
  tone           String?
  tagline        String?
  instructions   String?
  nicheSettings  Json?
  ragContextId   String?
  facebookPageId String?
  instagramId    String?
  linkedInUrl    String?
  tiktokUser     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  landingPages LandingPage[]
}

/// Join table for User <-> Tenant many-to-many relationship
model TenantUser {
  tenantId String @db.Uuid
  userId   String
  role     String @default("user")

  @@id([tenantId, userId])
}

/// Primary user/client record. Standardized to native UUID.
model User {
  id                     String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                  String    @unique
  name                   String?
  phone                  String?
  image                  String?
  dashboardToken         String?   @unique
  businessName           String?
  businessType           String?
  businessSize           String?
  revenueRange           String?
  status                 String    @default("active")
  role                   UserRole  @default(USER)
  emailVerified          Boolean   @default(false)
  n8nInstance            Json?
  activeServices         Json?
  entitlements           Json?
  stripeCustomerId       String?
  defaultPaymentMethodId String?
  billingAddress         Json?
  preferences            Json?
  source                 String?
  referrerId             String?
  qualificationScore     Int?
  qualificationTier      String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  lastLoginAt            DateTime?
  metrics                Json?

  brands Brand[]
  leads  Lead[]
}

/// NextAuth Account — kept for future OAuth integration
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
}

/// NextAuth Session — kept for future OAuth integration
model Session {
  id           String   @id @default(cuid())
  sessionToken String
  userId       String
  expires      DateTime
}

/// NextAuth VerificationToken — kept for future OAuth integration
/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@ignore
}

/// Custom magic-link authentication tokens
model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  clientId  String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Legacy custom-solutions client record (backward compat during migration)
model CustomSolutionsClient {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  email              String
  name               String
  websiteUrl         String?
  qualificationScore Int       @default(0)
  qualificationTier  String    @default("low")
  answers            Json?
  selectedTier       String?
  solutionPlan       Json?
  stripeSessionId    String?
  stripeCustomerId   String?
  amountPaid         Float?
  contractId         String?
  contractStatus     String?
  status             String    @default("qualified")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastLogin          DateTime?
}

/// Legacy client branding record
model Client {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  logoUrl           String?
  showLogoOnLanding Boolean  @default(false)
  privacySettings   Json?
  hebrew            Json?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Stripe payment events logged from webhooks
model Payment {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId           String?
  stripeSessionId  String?
  customerId       String?
  customerEmail    String?
  amountTotal      Int      @default(0)
  currency         String   @default("usd")
  flowType         String?
  productId        String?
  tier             String?
  platform         String   @default("superseller-web")
  createdAt        DateTime @default(now())
  amount           Int      @default(0)
  metadata         Json?
  status           String   @default("pending")
  stripeCustomerId String?
  updatedAt        DateTime @default(now()) @updatedAt
}

/// Marketplace purchase records with secure download tokens
model Purchase {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId          String
  templateId      String?
  customerEmail   String
  stripeSessionId String?
  downloadToken   String?
  downloadUrl     String?
  tier            String?
  createdAt       DateTime @default(now())
}

/// Template download events
model Download {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  templateId      String
  userEmail       String
  paymentIntentId String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())
  ip              String?
  userAgent       String?
}

/// Active service instances (marketplace installs, Core 7, etc.)
model ServiceInstance {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  clientId           String
  clientEmail        String
  productId          String?
  productName        String?
  status             String    @default("pending_setup")
  type               String?
  configuration      Json?
  n8nWorkflowId      String?
  adminNotes         String?
  stripeSessionId    String?
  whatsappInstanceId String?
  whatsappBundle     String?
  speedToLeadAverage Float?
  leadsCaptured      Int?
  appointmentsBooked Int?
  serviceId          String?
  parameters         Json?
  createdAt          DateTime  @default(now())
  activatedAt        DateTime?
  updatedAt          DateTime  @updatedAt
  tenantId           String?   @db.Uuid
  projectId          String?
  project            Project?  @relation("ServiceInstanceProject", fields: [projectId], references: [id])
}

/// Recurring subscriptions (WhatsApp, care plan, lead gen, content AI)
model Subscription {
  id                          String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId                      String
  userEmail                   String
  stripeSubscriptionId        String?
  stripeCustomerId            String?
  stripePriceId               String?
  subscriptionType            String
  whatsappBundle              String?
  whatsappInstanceId          String?
  carePlanTier                String?
  carePlanDeliverablesSummary Json?
  leadGenTier                 String?
  leadGenConfig               Json?
  amount                      Int             @default(0)
  currency                    String          @default("usd")
  billingInterval             BillingInterval @default(month)
  status                      String          @default("active")
  currentPeriodStart          DateTime?
  currentPeriodEnd            DateTime?
  cancelAtPeriodEnd           Boolean         @default(false)
  canceledAt                  DateTime?
  usageLimits                 Json?
  currentUsage                Json?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  tenantId                    String?         @db.Uuid
}

/// Monthly care plan deliverable tracking
model CarePlanDeliverable {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId           String
  subscriptionId   String
  carePlanTier     String
  periodStart      DateTime
  periodEnd        DateTime
  month            String
  deliverables     Json
  hoursAllocated   Float
  hoursUsed        Float     @default(0)
  hoursRemaining   Float
  status           String    @default("in_progress")
  completedAt      DateTime?
  notes            String?
  customerFeedback String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

/// Reusable service blueprints with pricing and n8n config
model ServiceManifest {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  slug        String
  description String
  type        String
  active      Boolean  @default(true)
  pricing     Json
  n8n         Json
  stripe      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Marketplace template/product catalog
model Template {
  id                        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                      String
  description               String?
  category                  String?
  price                     Float     @default(0)
  installPrice              Float?
  customPrice               Float?
  features                  Json?
  installation              Boolean?
  popular                   Boolean?
  version                   String?
  readinessStatus           String    @default("Draft")
  partner                   String?
  setupTime                 String?
  targetMarket              String?
  demoVideo                 String?
  previewImages             Json?
  downloadCount             Int       @default(0)
  image                     String?
  video                     String?
  rating                    Float?
  tools                     Json?
  content                   String?
  tags                      Json?
  outcomeHeadline           String?
  deploymentSteps           Json?
  name_he                   String?
  description_he            String?
  outcomeHeadline_he        String?
  features_he               Json?
  workflowId                String?
  technicalRequirements     Json?
  pricingConfig             Json?
  owner                     String?
  clientId                  String?
  department                String?
  n8nWorkflowId             String?
  n8nWorkflowUrl            String?
  stripeProductId           String?
  stripePriceId             String?
  showInMarketplace         Boolean   @default(true)
  showInAdminDashboard      Boolean   @default(true)
  showInClientDashboard     Boolean   @default(false)
  configurationSchema       Json?
  deliveryChecklist         Json?
  complexity                String?
  businessImpact            String?
  businessImpact_he         String?
  roiExample                String?
  roiExample_he             String?
  oneTimeCost               Float?
  maintenanceCost           Float?
  maintenanceExplanation    String?
  maintenanceExplanation_he String?
  aiPromptScript            String?
  soraVideoPrompt           String?
  guarantee                 String?
  guarantee_he              String?
  isTargetTier              Boolean?
  kpis                      Json?
  kpis_he                   Json?
  useCases                  Json?
  useCases_he               Json?
  faqs                      Json?
  faqs_he                   Json?
  creator                   Json?
  creator_he                Json?
  videoScripts              Json?
  lastAuditedAt             DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  integrations              Json?
  metrics                   Json?
}

/// Marketplace customization requests
model CustomizationRequest {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  templateId    String
  data          Json?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  customerEmail String?
  parameters    Json?
  updatedAt     DateTime @default(now()) @updatedAt
}

/// Solution catalog (Jan 2026 restructuring — outcome-focused products)
model Solution {
  id                    String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                  String
  description           String?
  outcomeHeadline       String?
  category              String?
  type                  String?
  status                String   @default("active")
  pricing               Json?
  features              Json?
  tools                 Json?
  video                 String?
  image                 String?
  tags                  Json?
  rating                Float    @default(0)
  downloads             Int      @default(0)
  partner               String?
  technicalRequirements Json?
  workflowTemplateId    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  instances SolutionInstance[]
}

/// Client-specific solution instance with deployment tracking
model SolutionInstance {
  id                   String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  solutionId           String
  solution             Solution  @relation(fields: [solutionId], references: [id])
  clientId             String
  clientEmail          String
  model                String    @default("builder")
  status               String    @default("pending_setup")
  configuration        Json?
  technicalPulse       Json?
  deploymentLog        Json?
  n8nWorkflowId        String?
  stripeSubscriptionId String?
  lastRunAt            DateTime?
  lastStatus           String?
  errorCount           Int       @default(0)
  provisionedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

/// WhatsApp AI agent instances per customer
model WhatsAppInstance {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  userEmail      String
  businessName   String?
  businessType   String?
  phoneNumber    String?
  wahaInstanceId String?
  n8nWorkflowId  String?
  bundle         String?
  bundleFeatures Json?
  addOns         Json?
  status         String    @default("pending_setup")
  metrics        Json?
  configuration  Json?
  subscriptionId String?
  carePlanId     String?
  createdAt      DateTime  @default(now())
  activatedAt    DateTime?
  updatedAt      DateTime  @updatedAt
  projectId      String?
  project        Project?  @relation("WhatsAppInstanceProject", fields: [projectId], references: [id])
}

/// Individual WhatsApp messages with speed-to-lead tracking
model WhatsAppMessage {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  whatsappInstanceId String
  userId             String
  from               String
  to                 String
  messageType        String
  content            String?
  direction          String
  responseTime       Float?
  isFirstContact     Boolean   @default(false)
  firstResponseTime  Float?
  leadStatus         String?
  qualificationData  Json?
  appointmentBooked  Json?
  escalatedToHuman   Boolean   @default(false)
  escalatedAt        DateTime?
  humanRespondedAt   DateTime?
  sessionId          String?
  metadata           Json?
  createdAt          DateTime  @default(now())
}

/// Appointments booked through WhatsApp AI
model AppointmentBooking {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  whatsappInstanceId String
  userId             String
  customerName       String
  customerPhone      String
  customerEmail      String?
  serviceType        String?
  appointmentDate    DateTime
  appointmentTime    String?
  duration           Int?
  location           String?
  status             String    @default("scheduled")
  confirmedAt        DateTime?
  reminderSent       Boolean   @default(false)
  reminderSentAt     DateTime?
  calendarEventId    String?
  calendarProvider   String?
  source             String    @default("whatsapp_ai")
  whatsappMessageId  String?
  notes              String?
  internalNotes      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// Lead records from all sources with speed-to-lead and conversion tracking
model Lead {
  id                  String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  source              String
  sourceId            String?
  userId              String
  subscriptionId      String?
  whatsappInstanceId  String?
  name                String?
  company             String?
  email               String?
  phone               String?
  website             String?
  location            Json?
  firstContactAt      DateTime?
  firstResponseAt     DateTime?
  responseTime        Float?
  responseTimeStatus  String?
  qualificationStatus String    @default("unqualified")
  qualificationData   Json?
  enrichedData        Json?
  status              String    @default("new")
  statusUpdatedAt     DateTime?
  deliveredAt         DateTime?
  deliveryMethod      String?
  convertedAt         DateTime?
  conversionValue     Float?
  conversionSource    String?
  tags                Json?
  notes               String?
  metadata            Json?
  syncedToAITable     Boolean   @default(false)
  transcript          String?
  rawAnalysis         Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenantId            String?   @db.Uuid

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

/// Free-leads trial requests
model LeadRequest {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  data      Json?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

/// Email / LinkedIn / multi-channel outreach campaigns
model OutreachCampaign {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  name      String?
  type      String?
  status    String   @default("draft")
  data      Json?
  metrics   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Monthly response-time analytics per user
model ResponseTimeMetrics {
  id                  String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String
  whatsappInstanceId  String?
  subscriptionId      String?
  period              String
  periodStart         DateTime
  periodEnd           DateTime
  totalLeads          Int      @default(0)
  averageResponseTime Float    @default(0)
  medianResponseTime  Float    @default(0)
  responseTimeBuckets Json
  conversionsBySpeed  Json
  targetResponseTime  Float    @default(300)
  goalMet             Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Agent execution logs (n8n runs, AI calls, etc.)
model UsageLog {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  clientId    String
  agentId     String    @default("system")
  status      String    @default("completed")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?
  model       String?
  tokens      Json?
  cost        Float     @default(0)
  output      String?
  metadata    Json?
  clientEmail String?
  serviceType String?
  tokenCount  Int?
  userId      String?
  tenantId    String?   @db.Uuid
}

/// Blog posts and social content (enhanced for SocialHub)
model ContentPost {
  id                String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId            String
  title             String?
  content           String?
  type              String?
  status            String           @default("draft")
  slug              String?
  metadata          Json?
  publishedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  platform          String?
  tenantId          String?          @db.Uuid
  mediaUrls         Json?
  platformPostId    String?
  platformUrl       String?
  scheduledAt       DateTime?        @db.Timestamptz(6)
  approvalStatus    String?
  approvedBy        String?
  approvedAt        DateTime?        @db.Timestamptz(6)
  rejectionNote     String?
  aiModel           String?
  aiPrompt          String?
  hashtags          Json?
  platformAccountId String?          @db.Uuid
  platformAccount   PlatformAccount? @relation(fields: [platformAccountId], references: [id])
  brandId           String?          @db.Uuid
}

/// Connected social media accounts (OAuth tokens)
model PlatformAccount {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String
  tenantId     String?       @db.Uuid
  platform     String
  accountName  String?
  accountId    String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?     @db.Timestamptz(6)
  scope        String?
  isActive     Boolean       @default(true)
  metadata     Json?
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  contentPosts ContentPost[]

  @@unique([userId, platform, accountId], name: "userId_platform_accountId")
}

/// Knowledge-base indexed documents (PDF, URL, text)
model IndexedDocument {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  clientId  String
  name      String
  type      String
  status    String    @default("processing")
  url       String?
  size      String?
  metadata  Json?
  indexedAt DateTime?
  createdAt DateTime  @default(now())
}

/// Voice / WhatsApp AI secretary configuration per client
model SecretaryConfig {
  id                  String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  clientId            String
  brandSlug           String?
  agentName           String?
  voiceId             String?
  greeting            String?
  tone                String?
  businessContext     String?
  phoneNumber         String?
  transferNumber      String?
  n8nWebhookId        String?
  whatsappEnabled     Boolean  @default(false)
  calendarEnabled     Boolean  @default(false)
  calendarLink        String?
  availability        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  telnyxAssistantId   String?
  telnyxPhoneNumberId String?
  leadConfig          Json?    @default("{}")
}

/// Voice call log entries (populated by FrontDesk poller from Telnyx conversations)
model VoiceCallLog {
  id                   String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId               String
  data                 Json
  createdAt            DateTime  @default(now())
  telnyxConversationId String?
  telnyxAssistantId    String?
  callerPhone          String?
  callerName           String?
  direction            String?
  duration             Int?      @default(0)
  outcome              String?   @default("answered")
  summary              String?
  sentiment            String?
  leadCaptured         Boolean?  @default(false)
  creditsCharged       Int?      @default(0)
  startedAt            DateTime? @db.Timestamptz(6)
  endedAt              DateTime? @db.Timestamptz(6)
  tenantId             String?   @db.Uuid
}

/// Customer support cases with AI reasoning
model SupportCase {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId       String
  workflowId       String?
  carePlanTier     String?
  submissionMethod String?
  issueDescription String
  contextData      Json?
  status           String   @default("pending")
  aiReasoningLog   Json?
  attemptCount     Int      @default(0)
  proposedFix      Json?
  resolution       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Content / workflow approval requests
model ApprovalRequest {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  clientId    String
  serviceId   String
  title       String
  description String?
  content     Json?
  status      String    @default("pending")
  requestedAt DateTime  @default(now())
  respondedAt DateTime?
  feedback    String?
  expiresAt   DateTime?
}

/// Client testimonials (linked to legacy Client model)
model Testimonial {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  clientId   String?
  language   String    @default("en")
  author     String?
  role       String?
  quote      String?
  result     String?
  imageUrl   String?
  label      String?
  order      Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?
  avatar     String?
  company    String?
  content    String?
  name       String?
  rating     Float?
}

/// Onboarding form submissions for solution setup
model OnboardingRequest {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  solutionId String?
  status     String    @default("draft")
  data       Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?
}

/// System audit trail
model Audit {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  service      String
  action       String
  status       String
  errorMessage String?
  details      Json?
  createdAt    DateTime @default(now())
}

/// Service health check results (monitoring system)
model ServiceHealth {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String   @map("service_id") @db.VarChar
  name      String   @db.VarChar
  category  String   @db.VarChar
  status    String   @db.VarChar
  latencyMs Int?     @map("latency_ms")
  message   String?
  details   Json?
  checkedAt DateTime @default(now()) @map("checked_at") @db.Timestamptz(6)

  @@map("service_health")
}

/// Alert rules for monitoring thresholds
model AlertRule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
