{
    "name": "Marketplace-Engine-Master",
    "nodes": [
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "minutes",
                            "minutesInterval": 30
                        }
                    ]
                }
            },
            "id": "trigger",
            "name": "Every 30 Minutes",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.1,
            "position": [
                200,
                300
            ]
        },
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "SELECT * FROM solution_instances WHERE type = 'marketplace_autoposter' AND status = 'active'"
            },
            "id": "fetch-instances",
            "name": "Fetch Active Instances",
            "type": "n8n-nodes-base.firestore",
            "typeVersion": 1,
            "position": [
                400,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const instance = $json;\nconst config = instance.config || {};\n\n// Determine Media Logic\nlet mediaEngine = 'static';\nlet videoUrl = config.staticVideoUrl || '';\nlet promptPrefix = '';\n\nif (instance.solutionId === 'missparty') {\n  mediaEngine = 'ai_gen';\n  promptPrefix = 'White inflatable bounce house, ';\n} else if (instance.solutionId === 'uad') {\n  mediaEngine = 'static';\n  videoUrl = '/opt/fb-marketplace-bot/ffb88fcc-ff51-4ce6-87f2-016eabca6a4d.mp4';\n  promptPrefix = 'Garage door installation, ';\n}\n\nreturn {\n  ...instance,\n  mediaEngine,\n  videoUrl,\n  promptPrefix,\n  targetCity: config.cities ? config.cities[Math.floor(Math.random() * config.cities.length)] : 'Dallas, Texas',\n  targetPhone: config.phoneNumbers ? config.phoneNumbers[Math.floor(Math.random() * config.phoneNumbers.length)] : '+1-000-000-0000'\n};"
            },
            "id": "router",
            "name": "Niche Logic Router",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                600,
                300
            ]
        },
        {
            "parameters": {
                "modelId": "claude-sonnet-4-5-20250929",
                "messages": {
                    "values": [
                        {
                            "content": "={{ 'Create a Facebook Marketplace listing for ' + $json.promptPrefix + '. Location: ' + $json.targetCity + '. Phone: ' + $json.targetPhone + '. Return JSON only.' }}"
                        }
                    ]
                }
            },
            "id": "ai-generator",
            "name": "Generate Copy",
            "type": "@n8n/n8n-nodes-langchain.anthropic",
            "typeVersion": 1,
            "position": [
                800,
                200
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "loose",
                        "version": 3
                    },
                    "conditions": [
                        {
                            "id": "media-check",
                            "leftValue": "={{ $json.mediaEngine }}",
                            "rightValue": "ai_gen",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                }
            },
            "id": "media-branch",
            "name": "Media Switch",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1000,
                300
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://api.kie.ai/api/v1/jobs/createTask",
                "jsonBody": "={{ JSON.stringify({ \"model\": \"bytedance/v1-pro-text-to-video\", \"input\": { \"prompt\": $json.promptPrefix + \" cinematic view\" } }) }}"
            },
            "id": "kie-video",
            "name": "Generate AI Video",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                1200,
                200
            ]
        },
        {
            "parameters": {
                "operation": "upsert",
                "dataTableId": "marketplace_cache",
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "uniqueHash": "={{ $json.id + '_' + Date.now() }}",
                        "status": "Ready",
                        "listingTitle": "={{ $json.listingTitle }}",
                        "videoUrl": "={{ $json.videoUrl }}"
                    }
                }
            },
            "id": "save-cache",
            "name": "Save to Cache",
            "type": "n8n-nodes-base.dataTable",
            "typeVersion": 1.1,
            "position": [
                1400,
                300
            ]
        }
    ],
    "connections": {
        "trigger": {
            "main": [
                [
                    {
                        "node": "fetch-instances",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "fetch-instances": {
            "main": [
                [
                    {
                        "node": "router",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "router": {
            "main": [
                [
                    {
                        "node": "ai-generator",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "ai-generator": {
            "main": [
                [
                    {
                        "node": "media-branch",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "media-branch": {
            "main": [
                [
                    {
                        "node": "kie-video",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "save-cache",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "kie-video": {
            "main": [
                [
                    {
                        "node": "save-cache",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    }
}