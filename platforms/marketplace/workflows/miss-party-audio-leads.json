    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this Telnyx conversation insight data and extract lead information.\n\nThe input contains conversation insights from Telnyx AI with a summary of the call.\n\nExtract the following from the conversation_insights result field:\n- Customer phone number (from the summary or metadata.from field)\n- Service address (look for address mentions in the summary)\n- Customer name\n- Appointment time\n- Garage door issues mentioned\n- Call outcome\n\nInput data:\n{{ JSON.stringify($json, null, 2) }}\n\n**IMPORTANT: You MUST respond with ONLY a valid JSON object matching the schema. No explanations, no markdown code blocks, just the raw JSON.**",
        "hasOutputParser": true,
        "options": {
          "maxIterations": 10,
          "returnIntermediateSteps": false
        }
      },
      "id": "6acf55e0-d988-48b1-989d-faa1c987cf71",
      "name": "Analyze and Categorize Audio1",
