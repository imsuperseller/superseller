            {
              "id": "id-2",
              "name": "emailBody",
              "value": "=<html>\n    .critical-info-title { font-weight: bold; color: #d32f2f; margin-bottom: 15px; font-size: 20px; text-align: center; }\n    .critical-field { background-color: white; padding: 12px; margin: 10px 0; border-radius: 4px; border-left: 4px solid #d32f2f; }\n    .critical-field-label { font-weight: bold; color: #1a3a5c; margin-bottom: 5px; }\n    .critical-field-value { font-size: 18px; color: #d32f2f; font-weight: bold; }\n    .missing-field { background-color: #ffebee; border-left: 4px solid #d32f2f; }\n    .lead-info { background-color: #f8f9fa; border-left: 4px solid #a0d468; padding: 15px; margin-bottom: 25px; border-radius: 4px; }\n    .lead-info-title { font-weight: bold; color: #1a3a5c; margin-bottom: 10px; font-size: 16px; }\n    .lead-info-item { margin: 5px 0; color: #555; }\n    .attachment-note { background-color: #e3f2fd; border: 2px solid #a0d468; padding: 12px; border-radius: 8px; margin-top: 10px; text-align: center; color: #1a3a5c; font-size: 14px; }\n    .section { margin-bottom: 25px; border-left: 4px solid #a0d468; padding-left: 20px; }\n    .section-title { font-weight: bold; color: #1a3a5c; margin-bottom: 12px; font-size: 18px; }\n    .priority-high { color: #d32f2f; font-weight: bold; background-color: #ffebee; padding: 4px 8px; border-radius: 4px; display: inline-block; }\n    .priority-medium { color: #f57c00; font-weight: bold; background-color: #fff3e0; padding: 4px 8px; border-radius: 4px; display: inline-block; }\n    .priority-low { color: #388e3c; font-weight: bold; background-color: #e8f5e9; padding: 4px 8px; border-radius: 4px; display: inline-block; }\n    ul { margin: 8px 0; padding-left: 25px; }\n    li { margin: 6px 0; color: #555; }\n    .footer { background-color: #1a3a5c; color: white; padding: 20px; text-align: center; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <div class=\"logo-section\">\n        <img src=\"http://172.245.56.50/missparty-logo.svg\" alt=\"Miss Party Premium Rentals\" class=\"logo\" />\n        <div class=\"company-name\">Miss Party Premium Rentals</div>\n        <div class=\"tagline\">Miss Party Premium Rentals</div>\n      </div>\n      <div class=\"lead-badge\">NEW LEAD - Facebook Marketplace</div>\n    </div>\n    <div class=\"content\">\n      <div class=\"critical-info\">\n        <div class=\"critical-info-title\">\ud83d\udea8 CRITICAL CONTACT INFORMATION</div>\n        <div class=\"critical-field {{ ($json.output[0].customerPhoneNumber && $json.output[0].customerPhoneNumber !== 'NOT PROVIDED') ? '' : 'missing-field' }}\">\n          <div class=\"critical-field-label\">\ud83d\udcde Customer Phone Number:</div>\n          <div class=\"critical-field-value\">{{ $json.output[0].customerPhoneNumber || 'NOT PROVIDED - URGENT: Follow up required!' }}</div>\n        </div>\n        <div class=\"critical-field {{ ($json.output[0].customerAddress && $json.output[0].customerAddress !== 'NOT PROVIDED') ? '' : 'missing-field' }}\">\n          <div class=\"critical-field-label\">\ud83d\udccd Service Address:</div>\n          <div class=\"critical-field-value\">{{ $json.output[0].customerAddress || 'NOT PROVIDED - URGENT: Follow up required!' }}</div>\n        </div>\n        {{ $json.output[0].customerName ? '<div class=\"critical-field\"><div class=\"critical-field-label\">\ud83d\udc64 Customer Name:</div><div class=\"critical-field-value\">' + $json.output[0].customerName + '</div></div>' : '' }}\n        {{ $json.output[0].appointmentTime ? '<div class=\"critical-field\"><div class=\"critical-field-label\">\ud83d\udcc5 Preferred Appointment Time:</div><div class=\"critical-field-value\">' + $json.output[0].appointmentTime + '</div></div>' : '' }}",
              "type": "string"
