    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"topic\": {\n      \"type\": \"string\",\n      \"description\": \"Main topic or reason for the call\"\n    },\n    \"customerPhoneNumber\": {\n      \"type\": \"string\",\n      \"description\": \"Customer phone number - CRITICAL field\"\n    },\n    \"customerAddress\": {\n      \"type\": \"string\", \n      \"description\": \"Full service address - CRITICAL field\"\n    },\n    \"customerName\": {\n      \"type\": \"string\",\n      \"description\": \"Customer full name\"\n    },\n    \"appointmentTime\": {\n      \"type\": \"string\",\n      \"description\": \"Scheduled or preferred appointment time\"\n    },\n    \"garageDoorIssues\": {\n      \"type\": \"array\",\n      \"items\": {\"type\": \"string\"},\n      \"description\": \"List of garage door problems mentioned\"\n    },\n    \"keyPoints\": {\n      \"type\": \"array\",\n      \"items\": {\"type\": \"string\"},\n      \"description\": \"Key discussion points\"\n    },\n    \"sentiment\": {\n      \"type\": \"string\",\n      \"description\": \"Customer sentiment: positive, neutral, frustrated, urgent\"\n    },\n    \"priority\": {\n      \"type\": \"string\",\n      \"description\": \"Priority: high, medium, low\"\n    },\n    \"category\": {\n      \"type\": \"string\",\n      \"description\": \"Service type: repair, installation, replacement, maintenance, emergency\"\n    },\n    \"actionItems\": {\n      \"type\": \"array\",\n      \"items\": {\"type\": \"string\"},\n      \"description\": \"Follow-up actions needed\"\n    },\n    \"participants\": {\n      \"type\": \"array\",\n      \"items\": {\"type\": \"string\"},\n      \"description\": \"Call participants\"\n    },\n    \"confidenceScore\": {\n      \"type\": \"number\",\n      \"description\": \"Data extraction confidence 0-1\"\n    },\n    \"bookingOutcome\": {\n      \"type\": \"string\",\n      \"description\": \"Call result: booked, callback_requested, declined, incomplete\"\n    },\n    \"callerPhoneNumber\": {\n      \"type\": \"string\",\n      \"description\": \"Phone number that called in (from Telnyx caller ID)\"\n    },\n    \"callDuration\": {\n      \"type\": \"string\",\n      \"description\": \"Length of the call if available\"\n    },\n    \"missingInfo\": {\n      \"type\": \"array\",\n      \"items\": {\"type\": \"string\"},\n      \"description\": \"List of critical info that was NOT collected\"\n    }\n  },\n  \"required\": [\"customerPhoneNumber\", \"customerAddress\", \"bookingOutcome\"]\n}"
      },
