[Unit]
Description=Cloudflare Tunnel for n8n Webflow OAuth2 Callback
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/cloudflared tunnel --url http://localhost:5678 --hostname n8n-webflow-oauth2.rensto.com
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
