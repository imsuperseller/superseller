    {
      "parameters": {
        "jsCode": "const propertySource = $input.item.json['Property Source'];\nconst zillowUrl = $input.item.json['Zillow URL'];\nconst address = $input.item.json['Property Address'];\nconst floorPlan = $input.item.json['Floor Plan Image'];\nconst email = $input.item.json['Email'];\n\nlet apifyInput = {};\n\nif (propertySource === 'Zillow URL' && zillowUrl) {\n  apifyInput = {\n    startUrls: [{ url: zillowUrl }],\n    maxImages: 10,\n    maxCrawledPlacesPerSearch: 1\n  };\n} else if (propertySource === 'Property Address' && address) {\n  apifyInput = {\n    searchStringsArray: [address],\n    maxCrawledPlacesPerSearch: 1,\n    maxImages: 10\n  };\n}\n\nconst executionId = $execution.id;\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData[executionId]) { staticData[executionId] = {}; }\nstaticData[executionId].email = email;\nstaticData[executionId].address = address || zillowUrl || 'Property';\n\nreturn [{\n  apifyInput,\n  floorPlan,\n  email,\n  executionId\n}];"
      },
      "id": "prepare_apify_input",
      "name": "PrepareApifyInput",
      "position": [
        704,
        480
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
