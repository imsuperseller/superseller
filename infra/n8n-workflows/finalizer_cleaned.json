      "name": "Execute Workflow Trigger",
      "position": [
        112,
        208
      ],
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1
    },
    {
      "parameters": {
        "jsCode": "const executionId = $input.item.json.executionId;\nconst staticData = $getWorkflowStaticData('global');\nconst scope = staticData[executionId] || {};\n// Sort by order, ensuring the latest timestamp for each order is used\nconst videos = (scope.videoUrls || []).sort((a, b) => a.order - b.order);\nreturn { \n  videoUrls: videos.map(v => v.url), \n  email: scope.email, \n  address: scope.address,\n  executionId\n};"
      },
      "id": "aggregate_results",
      "name": "AggregateResults (Code)",
      "position": [
        352,
        208
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://172.245.56.50:5050/merge",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "video_urls",
              "value": "={{ $json.videoUrls }}"
            },
            {
              "name": "address",
              "value": "={{ $json.address }}"
            },
            {
              "name": "output_format",
              "value": "mp4"
            },
            {
              "name": "quality",
              "value": "1080p"
            }
          ]
        },
        "options": {
