#!/usr/bin/env node

/**
 * n8n Instance Switcher - Simple wrapper for easy switching
 */

import { spawn } from 'child_process';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Simple commands
const commands = {
  'list': () => runScript('n8n-instance-manager.js', ['list']),
  'rensto': () => runScript('n8n-instance-manager.js', ['switch', 'rensto']),
  'safety': () => runScript('safety-guard.js', ['check']),
  'help': () => showHelp()
};

function runScript(script, args) {
  const scriptPath = path.join(__dirname, script);
  const child = spawn('node', [scriptPath, ...args], { 
    stdio: 'inherit',
    cwd: __dirname 
  });
  
  child.on('close', (code) => {
    process.exit(code);
  });
}

function showHelp() {
  console.log(`
n8n Instance Switcher
=====================

Quick Commands:
  n8n-switch list          - List all instances
  n8n-switch rensto        - Switch to Rensto VPS
  n8n-switch safety        - Run safety check
  n8n-switch help          - Show this help

Advanced Commands:
  node n8n-instance-manager.js <command>     - Full instance management
  node customer-instance-setup.js <command>  - Customer setup
  node safety-guard.js <command>             - Safety management

Examples:
  n8n-switch list
  n8n-switch rensto
  n8n-switch safety
  `);
}

// Main execution
const command = process.argv[2] || 'help';

if (commands[command]) {
  commands[command]();
} else {
  console.log(`Unknown command: ${command}`);
  showHelp();
  process.exit(1);
}
