    {
      "parameters": {
        "jsCode": "const existingItems = $input.all();\nconst existingConfigs = new Set();\nexistingItems.forEach(item => {\n  if (item.json.uniqueHash) existingConfigs.add(item.json.uniqueHash);\n});\n\nconst phoneNumber = \"+1-469-283-9855\";\nconst cities = [\"Dallas\", \"Fort Worth\", \"Arlington\", \"Plano\", \"Garland\", \"Irving\", \"McKinney\", \"Frisco\", \"Mesquite\", \"Grand Prairie\", \"Carrollton\", \"Richardson\", \"Lewisville\", \"Allen\", \"Flower Mound\"];\nconst scenarios = [\n  { setting: \"indoors\", kids: \"few\", balls: true, desc: \"Toddlers playing with colorful balls inside white bounce house in living room\" },\n  { setting: \"indoors\", kids: \"many\", balls: true, desc: \"Birthday party with kids jumping in white bouncy castle, colorful balls flying\" },\n  { setting: \"outdoors\", kids: \"few\", balls: false, desc: \"Two kids jumping in white bounce house in sunny backyard\" },\n  { setting: \"outdoors\", kids: \"many\", balls: true, desc: \"Backyard birthday party, white inflatable bouncer full of happy kids and balls\" },\n  { setting: \"indoors\", kids: \"few\", balls: false, desc: \"Kids jumping in white bounce house in garage, joyful moment\" },\n  { setting: \"outdoors\", kids: \"many\", balls: false, desc: \"Group of children bouncing in white inflatable castle at outdoor party\" }\n];\n\nfunction pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }\n\nconst scenario = pick(scenarios);\nconst city = pick(cities);\nconst hash = `missparty-${scenario.setting}-${scenario.kids}-${city}-${Date.now()}`;\n\nconst c = {\n  PhoneNumber: phoneNumber,\n  Location: city + ', Texas',\n  Setting: scenario.setting,\n  KidsCount: scenario.kids,\n  HasBalls: scenario.balls,\n  ScenarioDesc: scenario.desc,\n  uniqueHash: hash,\n  Price: 75,\n  ListingPrice: 75,\n  ProductName: \"White Bounce House Rental\",\n  ProductType: \"Inflatable Bouncer\",\n  Includes: \"Bouncy House, Blower, Undermat, Colorful Balls\",\n  RentalPeriod: \"24 hours\",\n  Delivery: \"Free pickup available. Delivery: $1/minute of driving.\",\n  Video_URL: '/opt/fb-marketplace-bot/video.mp4'\n};\n\nconst phone = 'CALL ' + c.PhoneNumber;\nreturn [{ json: { \n  ...c,\n  prompt1: `White inflatable bounce house, ${scenario.desc}, realistic photo, happy children, professional photography, bright natural lighting, text overlay: ${phone}`,\n  prompt2: `White bouncy castle ${scenario.setting === 'indoors' ? 'in living room' : 'in backyard'}, ${scenario.kids === 'many' ? 'multiple excited' : 'two happy'} kids jumping, ${scenario.balls ? 'colorful plastic balls everywhere' : 'clean white aesthetic'}, lifestyle photography`,\n  prompt3: `White inflatable bouncer rental setup, ${scenario.setting === 'outdoors' ? 'outdoor party setting' : 'indoor celebration'}, ${scenario.kids === 'many' ? 'birthday party atmosphere with children' : 'small family gathering'}, professional product photo`\n}}];"
