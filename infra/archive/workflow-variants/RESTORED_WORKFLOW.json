        "jsCode": "const d = $('Extract 7').first().json;\nlet title = d.ProductName + ' - ' + d.RentalPeriod + ' ' + d.ProductType;\nlet desc = d.ProductName + ' for rent! ' + d.RentalPeriod + ' rental includes: ' + d.Includes + '. ' + d.Delivery + ' Price: $' + d.ListingPrice + '. CALL ' + d.PhoneNumber + '!';\ntry { \n  const t = $json.message?.content?.[0]?.text || ''; \n  const m = t.match(/\\{[\\s\\S]*\\}/); \n  if (m) { \n    const p = JSON.parse(m[0]); \n    title = p.title || title; \n    desc = p.description || desc; \n  } \n} catch(e) {}\nreturn [{ json: { ...d, ListingTitle: title, ListingDescription: desc } }];"
