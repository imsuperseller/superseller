{
  "purpose": "Rensto Global ID system for unique identification across all systems",
  "format": "RGID_[SYSTEM]_[TYPE]_[DATE]_[SEQUENCE]",
  "examples": [
    "RGID_NOTION_BUSINESS_REF_20240922_001",
    "RGID_AIRTABLE_COMPANY_20240922_001",
    "RGID_PROJECT_TRACKING_20240922_001"
  ],
  "implementation": {
    "notion": {
      "fieldName": "RGID",
      "fieldType": "Rich Text",
      "description": "Unique identifier for cross-system synchronization",
      "required": true
    },
    "airtable": {
      "fieldName": "RGID",
      "fieldType": "Single Line Text",
      "description": "Unique identifier for cross-system synchronization",
      "required": true
    },
    "sync": {
      "primaryKey": "RGID",
      "conflictResolution": "notion_priority",
      "validation": "format_check"
    }
  }
}