    {
      "parameters": {
        "jsCode": "// Parse Stripe webhook data\nconst webhookNode = $input.first().json;\n\n// Extract body from webhook node (webhook node wraps data in 'body')\nconst body = webhookNode.body || webhookNode;\nconst webhookData = body.webhookData || body;\nconst metadata = body.metadata || webhookData.metadata || {};\n\n// Extract data from webhook payload (check multiple possible locations)\nconst customerEmail = body.customerEmail || webhookData.customerEmail || metadata.customerEmail || '';\nconst customerName = body.customerName || webhookData.customerName || metadata.customerName || '';\nconst amount = body.amount || webhookData.amount || metadata.amount || 0;\nconst productId = body.productId || webhookData.productId || metadata.productId || '';\nconst sessionId = body.stripeSessionId || webhookData.stripeSessionId || body.sessionId || webhookData.sessionId || '';\nconst flowType = body.flowType || webhookData.flowType || metadata.flowType || 'marketplace-template';\nconst tier = body.tier || webhookData.tier || metadata.tier || 'simple';\nconst templateName = metadata.templateName || metadata.productName || webhookData.templateName || webhookData.productName || '';\n\nreturn [{\n  customerEmail,\n  customerName,\n  amount,\n  productId, // This should match Workflow ID in Marketplace Products\n  sessionId,\n  flowType,\n  tier,\n  templateName,\n  purchaseType: 'Download',\n  timestamp: new Date().toISOString(),\n  // Store full webhook data for reference\n  webhookData: {\n    customerEmail,\n    customerName,\n    amount,\n    productId,\n    sessionId,\n    flowType,\n    tier,\n    templateName\n  }\n}];"
      },
      "id": "parse-data",
      "name": "Parse Webhook Data",
      "type": "n8n-nodes-base.code",
