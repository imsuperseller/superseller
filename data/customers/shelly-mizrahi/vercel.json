{
  "version": 2,
  "builds": [
    {
      "src": "website/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "scripts/simulate-ben-customer-journey.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/website/index.html"
    },
    {
      "src": "/demo-ben",
      "dest": "/website/demo-ben.html"
    },
    {
      "src": "/api/contact",
      "dest": "/scripts/simulate-ben-customer-journey.js"
    },
    {
      "src": "/api/demo/tax4us",
      "dest": "/scripts/simulate-ben-customer-journey.js"
    },
    {
      "src": "/(.*)",
      "dest": "/website/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
} 