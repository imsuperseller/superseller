            "parameters": {
                "jsCode": "// Rensto Topic Rotation Logic\nconst pillars = [\n  { id: 'rag', name: 'Knowledge Engine (RAG)', focus: 'Internal Search, Employee Training, Instant Answers' },\n  { id: 'leads', name: 'Lead Machine (Outbound)', focus: 'Cold Email, Scraping, Data Enrichment' },\n  { id: 'secretary', name: 'Autonomous Secretary (Voice)', focus: 'Inbound Calls, Booking, Customer Service' },\n  { id: 'content', name: 'Content Engine', focus: 'SEO, Social Automation, Viral Scripts' }\n];\n\n// Simple Rotation based on execution ID randomness + day\nconst randomIdx = Math.floor(Math.random() * pillars.length);\nconst selectedPillar = pillars[randomIdx];\n\nreturn {\n  json: {\n    topic: selectedPillar.name,\n    focus: selectedPillar.focus,\n    targetAudience: \"SMB Owners ($2M-$10M ARR)\",\n    tone: \"Professional, Skeptical-Friendly, ROI-Focused\"\n  }\n};\n"
            },
