            "parameters": {
                "jsCode": "const data = $input.item.json;\nconst MAX_RETRIES = 60;\nconst retryCount = data.retryCount || 0;\n\nif (retryCount >= MAX_RETRIES) {\n  return { json: { ...data, isReady: false, retryCount: 0, reason: 'Timeout' } };\n}\n\nconst state = data.data?.state;\n\nif (state === 'success') {\n  let resultUrls = [];\n  try {\n    if (data.data.resultJson) {\n      const parsed = JSON.parse(data.data.resultJson);\n      resultUrls = parsed.resultUrls || [];\n    }\n  } catch (e) {}\n  \n  return { json: { ...data, isReady: true, retryCount: 0, resultUrls: resultUrls } };\n} else if (state === 'fail' || state === 'failed') {\n  return { json: { ...data, isReady: false, retryCount: 0, reason: 'Failed' } };\n}\n\nreturn { json: { ...data, isReady: false, retryCount: retryCount + 1 } };"
            },
