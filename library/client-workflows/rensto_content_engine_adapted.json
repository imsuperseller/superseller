                "jsCode": "// Extract content for LinkedIn vs Blog\nconst aiOutput = $json.text || '';\nlet linkedInPost = '';\nlet blogPost = '';\nlet title = '';\nlet imagePrompt = '';\nlet videoPrompt = '';\n\n// Try to parse JSON if the AI returned it\ntry {\n  const cleanJson = aiOutput.replace(/```json/g, '').replace(/```/g, '').trim();\n  const parsed = JSON.parse(cleanJson);\n  linkedInPost = parsed.linkedin;\n  blogPost = parsed.blog;\n  title = parsed.title;\n  imagePrompt = parsed.image_prompt || `Hyper-realistic minimalist photography of ${title}, 8k resolution, cinematic lighting`;\n  videoPrompt = parsed.video_prompt || `Cinematic shot of ${title}, modern business setting, 4k`;\n} catch (e) {\n  // Fallback: Use raw text\n  linkedInPost = aiOutput.substring(0, 2000); \n  title = 'AI Automation Update';\n  imagePrompt = 'Abstract tech background, blue and purple gradient, 8k, high quality';\n  videoPrompt = 'Futuristic data visualization, glowing nodes, 4k loop';\n}\n\nreturn {\n  json: {\n    linkedInContent: linkedInPost,\n    blogContent: blogPost,\n    title: title,\n    imagePrompt: imagePrompt,\n    videoPrompt: videoPrompt,\n    status: 'pending_approval'\n  }\n};\n"
