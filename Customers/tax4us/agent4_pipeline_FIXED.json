      "parameters": {
        "jsCode": "\n// Check if Ben responded or timeout\nconst approved = $input.item.json.approved || false;\nconst choice = $input.item.json.choice || 1;  // Default to Topic 1\n\n// Extract topics from OpenAI response\nconst aiResponse = $('OpenAI: Generate Topics').item.json.choices[0].message.content;\nconst topicMatch = aiResponse.match(/Topic (\\d): (.+?)\\nSummary: (.+?)(?=\\n\\nTopic|$)/gs);\n\nlet selectedTopic = '';\nif (topicMatch && topicMatch[choice - 1]) {\n  selectedTopic = topicMatch[choice - 1];\n} else {\n  selectedTopic = 'Topic 1: Default topic (parsing failed)';\n}\n\nreturn {\n  approved,\n  choice,\n  selectedTopic,\n  episode_id: $('Code: Extract Phase').item.json.episode_id\n};\n"
      },
