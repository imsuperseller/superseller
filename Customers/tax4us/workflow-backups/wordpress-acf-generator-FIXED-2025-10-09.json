      "parameters": {
        "jsCode": "\nconst content = $input.item.json.choices[0].message.content;\nconst contentType = $('Airtable Trigger').item.json.fields['Type'];\nconst title = $('Airtable Trigger').item.json.fields['Title'];\n\n// Parse OpenAI JSON response (if JSON format)\nlet acfFields = {};\ntry {\n  const parsed = JSON.parse(content);\n  acfFields = parsed;\n} catch (e) {\n  // If not JSON, structure as simple content\n  acfFields = {\n    content_html: content\n  };\n}\n\nreturn {\n  title,\n  content_type: contentType,\n  acf_fields: acfFields,\n  slug: title.toLowerCase().replace(/[^a-z0-9]+/g, '-'),\n  record_id: $('Airtable Trigger').item.json.id\n};\n"
