    {
      "id": "preprocess-node",
      "name": "Preprocess Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        400
      ],
      "parameters": {
        "jsCode": "const execId = `blog_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;\nconst data = $input.item.json;\n\nconst title = data.fields?.['Title EN'] || data.fields?.['Title'] || '';\nconst topic = data.fields?.['Topic'] || data.fields?.['Outline'] || '';\nconst keywords = data.fields?.['Keywords'] || '';\nconst contentType = data.fields?.['Type'] || 'blog';\nconst status = data.fields?.['Status'] || 'pending';\nconst language = data.fields?.['Language'] || 'en';\nconst wordCount = parseInt(data.fields?.['Word Count'] || 2500);\n\nconst isValid = title.length > 5 && topic.length > 20;\nconst shouldProcess = isValid && (status === 'Approved' || status === 'pending');\n\nreturn {\n  json: {\n    execId,\n    recordId: data.id,\n    shouldProcess,\n    title,\n    topic,\n    keywords,\n    contentType,\n    language,\n    wordCount,\n    originalData: data\n  }\n};"
      }
    },
    {
      "id": "router-node",
      "name": "Should Process",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        600,
        400
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.shouldProcess }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "research-node",
      "name": "Research Topic",
      "type": "@mendable/n8n-nodes-firecrawl.firecrawl",
      "typeVersion": 1,
      "position": [
        800,
        300
      ],
      "parameters": {
        "operation": "search",
        "query": "={{ $json.keywords + ' ' + $json.topic }}",
        "requestOptions": {
          "limit": 5
        }
      },
      "credentials": {
        "firecrawlApi": {
          "id": "uDRaxyTyX1P90Eit",
          "name": "Firecrawl API"
        }
      }
    },
    {
      "id": "generate-content-node",
      "name": "Generate Content",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        1000,
        300
      ],
      "parameters": {
        "resource": "chat",
        "operation": "completion",
        "model": "gpt-4o",
        "messages": {
          "messageValues": [
            {
              "role": "system",
              "content": "You are an expert blog writer. Create a comprehensive, SEO-optimized blog post with proper structure, engaging content, and actionable insights."
            },
            {
              "role": "user",
              "content": "Write a complete blog post about: {{ $json.topic }}\\nKeywords: {{ $json.keywords }}\\nWord Count: {{ $json.wordCount }}\\n\\nInclude: introduction, main sections with H2/H3 headings, key takeaways, conclusion, and 3 FAQs. Format in Markdown."
            }
          ]
        },
        "options": {
          "temperature": 0.7,
          "maxTokens": 4000
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "IVfkaQOIs6jCRdyu",
          "name": "OpenAi account"
        }
      }
    },
    {
      "id": "format-content-node",
      "name": "Format for WordPress",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ],
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst content = d.choices?.[0]?.message?.content || d.content || '';\n\n// Convert Markdown to Gutenberg blocks\nfunction convertToGutenberg(markdown) {\n  let blocks = [];\n  const lines = markdown.split('\\n');\n  \n  lines.forEach(line => {\n    if (line.startsWith('# ')) {\n      blocks.push(`<!-- wp:heading {\\\"level\\\":1} -->\\n<h1>${line.replace('# ', '')}</h1>\\n<!-- /wp:heading -->`);\n    } else if (line.startsWith('## ')) {\n      blocks.push(`<!-- wp:heading {\\\"level\\\":2} -->\\n<h2>${line.replace('## ', '')}</h2>\\n<!-- /wp:heading -->`);\n    } else if (line.startsWith('### ')) {\n      blocks.push(`<!-- wp:heading {\\\"level\\\":3} -->\\n<h3>${line.replace('### ', '')}</h3>\\n<!-- /wp:heading -->`);\n    } else if (line.startsWith('- ')) {\n      blocks.push(`<!-- wp:list -->\\n<ul><li>${line.replace('- ', '')}</li></ul>\\n<!-- /wp:list -->`);\n    } else if (line.trim()) {\n      blocks.push(`<!-- wp:paragraph -->\\n<p>${line}</p>\\n<!-- /wp:paragraph -->`);\n    }\n  });\n  \n  return blocks.join('\\n\\n');\n}\n\nconst gutenbergContent = convertToGutenberg(content);\nconst slug = d.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');\n\nreturn {\n  json: {\n    ...d,\n    wpContent: gutenbergContent,\n    wpTitle: d.title,\n    wpSlug: slug,\n    wpExcerpt: content.substring(0, 155) + '...'\n  }\n};"
      }
    },
    {
      "id": "create-post-node",
      "name": "Create WordPress Post",
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [
        1400,
        300
      ],
      "parameters": {
        "resource": "post",
        "operation": "create",
        "title": "={{ $json.wpTitle }}",
        "additionalFields": {
          "content": "={{ $json.wpContent }}",
          "slug": "={{ $json.wpSlug }}",
          "excerpt": "={{ $json.wpExcerpt }}",
          "status": "draft"
        }
      },
      "credentials": {
        "wordpressApi": {
          "id": "GjqU4oaqFsD4KT0i",
          "name": "Wordpress account"
        }
