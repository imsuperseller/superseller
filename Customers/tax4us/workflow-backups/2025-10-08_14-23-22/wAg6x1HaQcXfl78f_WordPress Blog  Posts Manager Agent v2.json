        "baseId": {
          "__rl": true,
          "value": "appkZD1ew4aKoBqDM",
          "mode": "id"
        },
        "tableId": {
          "__rl": true,
          "value": "tbloWUmXIuBQXa1YQ",
          "mode": "id"
        },
