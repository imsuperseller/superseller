      "parameters": {
        "jsCode": "const execId = `exec_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;const data = $input.item.json;const title = data.fields['Title EN'] || data.fields['Title HE'] || '';const outline = data.fields['Outline'] || '';const postType = data.fields['Type'] || '';const status = data.fields['Status'] || '';const language = data.fields['Language'] || 'en';const keywords = data.fields['Keywords'] || '';const chapters = data.fields['Chapters'] || 4;const wordCount = data.fields['Word Count'] || 1500;const slugRaw = data.fields['Slug EN'] || data.fields['Slug HE'] || title;const slug = (slugRaw || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');const tooShort = outline.trim().length < 100 || title.trim().length < 10;const missingType = !postType || postType === '';const notApproved = status !== 'Approved';const notPostType = postType !== 'post' && postType !== 'blog' && postType !== 'article' && postType !== 'service' && postType !== 'blog_post';const shouldProcess = !tooShort && !missingType && !notApproved && !notPostType;let rejectReason = '';if (tooShort) rejectReason = 'Insufficient specification (outline < 100 chars or title < 10 chars)';else if (missingType) rejectReason = 'Missing Type';else if (notApproved) rejectReason = 'Not approved for processing';else if (notPostType) rejectReason = 'Not a post type (must be post, blog, article, service, or blog_post)';else rejectReason = 'Valid';return { json: { execId, recordId: data.id, shouldProcess, rejectReason, title, slug, language, outline, postType, status, keywords, chapters: parseInt(chapters), wordCount: parseInt(wordCount), originalData: data } };"
      },
