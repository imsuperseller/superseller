    {
      "parameters": {
        "jsCode": "const data = $input.item.json;nconst content = data.choices?.[0]?.message?.content;nif (!content) throw new Error('Missing OpenAI response');nnlet structure;ntry {n  structure = JSON.parse(content);n} catch (e) {n  throw new Error('Invalid JSON structure: ' + e.message);n}nnif (!structure.title || !structure.introduction || !structure.conclusions || !structure.chapters) {n  throw new Error('Missing required structure fields');n}nnif (!Array.isArray(structure.chapters) || structure.chapters.length === 0) {n  throw new Error('Chapters must be a non-empty array');n}nnreturn { json: { ...data, structure, chapterCount: structure.chapters.length } };"
      },
      "id": "validate-structure",
      "name": "Code: Validate Structure",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1232,
        480
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;nconst structure = data.structure;nnconst makeHeading = (level, text) => `<!-- wp:heading {\\\"level\\\":${level}} --><h${level}>${text}</h${level}><!-- /wp:heading -->`;nconst makeParagraph = (html) => `<!-- wp:paragraph --><p>${html}</p><!-- /wp:paragraph -->`;nconst makeList = (items) => `<!-- wp:list --><ul>${items.map(i=>`<li>${i}</li>`).join('')}</ul><!-- /wp:list -->`;nnconst slug = data.slug;nconst toc = structure.chapters && structure.chapters.length ? n  `<!-- wp:heading {\\\"level\\\":3} --><h3>Table of Contents</h3><!-- /wp:heading -->${makeList(structure.chapters.map((c,i)=>`<a href=\\\"#${slug}-sec-${i+1}\\\">${c.title}</a>`))}` : '';nnlet content = '';ncontent += toc;ncontent += makeParagraph(structure.introduction);nn// Process each chapter directly from the structurenfor (let i = 0; i < structure.chapters.length; i++) {n  const chapter = structure.chapters[i];n  const title = chapter.title || `Section ${i+1}`;n  n  content += `<!-- wp:html --><a id=\\\"${slug}-sec-${i+1}\\\"></a><!-- /wp:html -->`;n  content += makeHeading(2, title);n  n  const body = chapter.content || '';n  if (body.includes('<ul') || body.includes('<ol')) {n    content += body;n  } else {n    content += makeParagraph(body);n  }n}nncontent += makeHeading(3, 'Conclusions');ncontent += makeParagraph(structure.conclusions);nnconst postContent = {n  title: structure.title,n  slug: data.slug,n  content,n  excerpt: structure.subtitle || structure.introduction?.slice(0,155) || '',n  imagePrompt: structure.imagePrompt || '',n  tags: ['tax planning','small business','financial advice'],n  categories: ['Business','Tax Planning']n};nnreturn { json: { ...data, postContent, wpSlug: data.slug } };"
      },
