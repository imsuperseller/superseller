      "parameters": {
        "jsCode": "// Generate execution ID and prefilternconst execId = `exec_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;nconst data = $input.item.json;nn// Extract fields (map to actual Airtable names)nconst title = data['Title EN'] || data['Title HE'] || '';nconst outline = data['Outline'] || '';nconst pageType = data['Type'] || '';nconst status = data['Status'] || '';nconst language = data['Language'] || 'en';nn// Slug: prefer explicit, else from titlenconst slugRaw = data['Slug EN'] || data['Slug HE'] || title;nconst slug = (slugRaw || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');nn// Validation rulesnconst tooShort = outline.trim().length < 60 || title.trim().length < 5;nconst missingType = !pageType || pageType === '';nconst notApproved = status !== 'Approved';nnconst shouldProcess = !tooShort && !missingType && !notApproved;nlet rejectReason = '';nif (tooShort) rejectReason = 'Insufficient specification (outline < 60 chars or title < 5 chars)';nelse if (missingType) rejectReason = 'Missing Type';nelse if (notApproved) rejectReason = 'Not approved for processing';nelse rejectReason = 'Valid';nnreturn {n  json: {n    execId,n    recordId: data.id,n    shouldProcess,n    rejectReason,n    title,n    slug,n    language,n    outline,n    pageType,n    status,n    originalData: datan  }n};"
      },
