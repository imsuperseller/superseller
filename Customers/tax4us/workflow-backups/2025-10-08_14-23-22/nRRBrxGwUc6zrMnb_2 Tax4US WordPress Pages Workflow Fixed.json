        "jsCode": "// Validate and parse OpenAI responsenconst data = $input.item.json;nconst aiResponse = data.choices[0].message.content;nntry {n  const parsed = JSON.parse(aiResponse);n  n  // Required fields validationn  const required = ['title', 'slug', 'content', 'excerpt', 'sections', 'faqs', 'schema_jsonld', 'cta', 'meta'];n  const missing = required.filter(field => !parsed[field]);n  n  if (missing.length > 0) {n    throw new Error(`Missing required fields: ${missing.join(', ')}`);n  }n  n  // Validate structuren  if (!Array.isArray(parsed.sections) || parsed.sections.length < 3) {n    throw new Error('Sections must be an array with at least 3 items');n  }n  if (!Array.isArray(parsed.faqs) || parsed.faqs.length < 3) {n    throw new Error('FAQs must be an array with at least 3 items');n  }n  n  return {n    json: {n      execId: data.execId,n      recordId: data.recordId,n      originalData: data.originalData,n      pageContent: parsed,n      wpSlug: parsed.slug || data.slugn    }n  };n} catch (error) {n  throw new Error(`JSON validation failed: ${error.message}`);n}"
