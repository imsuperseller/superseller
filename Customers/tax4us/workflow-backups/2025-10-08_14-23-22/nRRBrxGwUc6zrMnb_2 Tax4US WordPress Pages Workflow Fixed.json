      "parameters": {
        "jsCode": "// Build OpenAI request payloadnconst data = $input.item.json;nnconst systemPrompt = `You are a WordPress content specialist. Generate a complete WordPress page as JSON with these exact fields:n- title: SEO-optimized title (60-70 chars)n- slug: URL-friendly slugn- content: Full HTML content with proper headings and sectionsn- excerpt: Meta description (155 chars max)n- sections: Array of {heading, content} objects (min 3 sections)n- faqs: Array of {question, answer} objects (min 3 FAQs)n- schema_jsonld: Valid JSON-LD structured data for the page typen- cta: Call-to-action object {text, link, button_text}n- meta: {og_title, og_description, keywords (comma-separated), hero_subtitle}`;nnconst userPrompt = `Create a ${data.pageType} page in ${data.language}:nTitle: ${data.title}nOutline: ${data.outline}nnReturn ONLY valid JSON. Ensure all text is properly escaped for JSON.`;nnreturn {n  json: {n    ...data,n    openaiPayload: {n      model: 'gpt-4o',n      response_format: { type: 'json_object' },n      temperature: 0.7,n      max_tokens: 4000,n      messages: [n        { role: 'system', content: systemPrompt },n        { role: 'user', content: userPrompt }n      ]n    }n  }n};"
      },
