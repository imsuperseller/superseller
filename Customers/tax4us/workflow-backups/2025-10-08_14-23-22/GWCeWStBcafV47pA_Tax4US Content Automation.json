    {
      "parameters": {
        "jsCode": "// Handle records that don't meet validation criterianconst invalidRecords = $input.all();nnconsole.log(`Found ${invalidRecords.length} invalid records`);nn// Log invalid records for debuggingninvalidRecords.forEach(record => {n  console.log(\"Invalid record:\", {n    id: record.json.id,n    wpPostId: record.json.fields[\"WP Post ID\"],n    reason: \"Missing required WP Post ID\"n  });n});nn// Return empty array to continue workflownreturn [];"
      },
