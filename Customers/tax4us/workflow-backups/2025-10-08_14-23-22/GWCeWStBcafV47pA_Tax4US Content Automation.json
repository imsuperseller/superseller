    {
      "parameters": {
        "jsCode": "// Normalize Airtable records to ensure consistent field structurenconst records = $input.all();nnif (records.length === 0) {n  throw new Error(\"No records found in Airtable\");n}nn// Define all expected fields from the table schemanconst expectedFields = [n  \"WP Post ID\", \"Spec ID\", \"Language\", \"Category\", \"Tags\", \"Excerpt\", n  \"Featured Image URL\", \"URL\", \"Preview URL\", \"Drafted At\", \"Published At\", n  \"State\", \"Last Error\", \"Title EN\", \"Slug EN\", \"Content_Specs.Language\", n  \"Agents\", \"id\", \"topic\", \"source_urls\", \"audience\", \"languages\", n  \"publish_on\", \"due_date_ct\", \"due_date_il\", \"publish_date\", \"cta_kind\", n  \"cta_link\", \"status\", \"review_email\", \"brand_tone\", \"post_json\", n  \"precheck_json\", \"errors\", \"utm_campaign\", \"utm_source\", \"utm_medium\", n  \"linkedin_post_id\", \"facebook_post_id\", \"twitter_post_id\", \"engagement_score\", n  \"impressions\", \"clicks\", \"shares\", \"published_at\", \"created_by\", n  \"approved_by\", \"approval_timestamp\", \"keywords\", \"hashtags\", \"complexity\", n  \"compliance_score\", \"violations\", \"ai_model_used\", \"api_cost\", n  \"attachments\", \"notes\"n];nn// Normalize each record to have all expected fieldsnconst normalizedRecords = records.map(record => {n  const normalizedRecord = { ...record.json };n  n  // Ensure all expected fields exist with default values if missingn  expectedFields.forEach(field => {n    if (!(field in normalizedRecord.fields)) {n      normalizedRecord.fields[field] = null;n    }n  });n  n  return normalizedRecord;n});nnconsole.log(`Normalized ${normalizedRecords.length} records to ensure field consistency`);nnreturn normalizedRecords;"
      },
      "id": "code-1",
      "name": "Normalize Field Structure",
