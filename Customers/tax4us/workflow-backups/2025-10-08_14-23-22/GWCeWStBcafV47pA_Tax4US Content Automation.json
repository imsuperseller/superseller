    {
      "parameters": {
        "jsCode": "// Process a single valid recordnconst record = $input.first().json;nn// Extract key information for content generationnconst contentData = {n  wpPostId: record.fields[\"WP Post ID\"] || \"\",n  language: record.fields[\"Language\"] || \"en\",n  category: record.fields[\"Category\"] || \"Tax Blog\",n  tags: record.fields[\"Tags\"] || \"\",n  excerpt: record.fields[\"Excerpt\"] || \"\",n  title: record.fields[\"Title EN\"] || \"\",n  slug: record.fields[\"Slug EN\"] || \"\",n  specId: record.fields[\"Spec ID\"] || null,n  agents: record.fields[\"Agents\"] || nulln};nn// Validate required fieldsnif (!contentData.wpPostId) {n  throw new Error(\"WP Post ID is required\");n}nnconsole.log(\"Processing record:\", contentData.wpPostId);nnreturn {n  contentData,n  originalRecord: recordn};"
      },
      "id": "code-2",
