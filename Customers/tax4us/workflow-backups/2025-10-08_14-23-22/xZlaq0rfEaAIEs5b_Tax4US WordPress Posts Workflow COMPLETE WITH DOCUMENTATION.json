      "id": "smart-prefilter",
      "name": "Code: Smart Prefilter with Caching",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        576
      ],
      "parameters": {
        "jsCode": "const execId = `exec_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;const data = $input.item.json;const title = data.fields['Title EN'] || data.fields['Title HE'] || '';const outline = data.fields['Outline'] || '';const postType = data.fields['Type'] || '';const status = data.fields['Status'] || '';const language = data.fields['Language'] || 'en';const keywords = data.fields['Keywords'] || '';const slugRaw = data.fields['Slug EN'] || data.fields['Slug HE'] || title;const slug = (slugRaw || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');// Smart validation with caching logicconst tooShort = outline.trim().length < 100 || title.trim().length < 10;const missingType = !postType || postType === '';const notApproved = status !== 'Approved';const notPostType = postType !== 'blog_post' && postType !== 'service' && postType !== 'faq' && postType !== 'glossary' && postType !== 'case_study';// Check if already processed (basic caching) - WP_Posts is a linked reco"
      },
      "onError": "continueRegularOutput"
    },
