      ],
      "parameters": {
        "jsCode": "const data = $input.item.json;const validations = {  contentGenerated: !!data.content,  imageGenerated: !!data.image,  postCreated: !!data.postId,  validationPassed: data.qualityScore > 7};const allValid = Object.values(validations).every(Boolean);const summary = {  success: allValid,  execId: data.execId,  postId: data.postId,  qualityScore: data.qualityScore,  costEstimate: data.costEstimate,  executionTime: Date.now() - parseInt(data.execId.split('_')[1]),  validations,  timestamp: new Date().toISOString()};return { json: { ...data, ...summary } };"
      },
      "onError": "continueRegularOutput"
