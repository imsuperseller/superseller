                            "type": "json_schema",
                            "schema": "{\"type\":\"object\",\"properties\":{\"projectScope\":{\"type\":\"string\"},\"deliverables\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"timeline\":{\"type\":\"string\"},\"setupFee\":{\"type\":\"number\"},\"monthlyFee\":{\"type\":\"number\"},\"paymentTerms\":{\"type\":\"string\"},\"startDate\":{\"type\":\"string\"}},\"required\":[\"projectScope\",\"deliverables\",\"timeline\",\"setupFee\",\"monthlyFee\",\"paymentTerms\",\"startDate\"],\"additionalProperties\":false}",
                            "strict": true
