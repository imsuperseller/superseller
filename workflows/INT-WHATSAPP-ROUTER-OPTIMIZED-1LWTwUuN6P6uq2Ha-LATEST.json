    {
      "parameters": {
        "jsCode": "// Normalize WAHA events into a stable message schema\nconst e = $input.first().json;\n\n// --- session\nconst session_id = e.session || e.sessionId || e?.session?.name || 'default';\n\n// --- message type\nconst message_type = e?.payload?.type || e?.type || e?.message?.type || 'text';\n\n// --- chat id (best-effort across engines)\nconst raw_chat_id =\n  e?.payload?.from ||\n  e?.chatId ||\n  e?.chat?.id ||\n  e?.payload?.chatId ||\n  e?.message?.from ||\n  e?.payload?.chat?.id ||\n  '';\n\n// WAHA expects: international phone digits (no '+') + '@c.us' for DMs\n// It may also emit '@s.whatsapp.net' internally; convert that to '@c.us' when sending.\nfunction normalizeChatId(v) {\n  if (!v) return '';\n  const s = String(v).trim();\n  if (s.includes('@')) {\n    const [id, domainRaw] = s.split('@');\n    const digits = id.replace(/\\D/g, '');\n    let domain = domainRaw;\n    if (domain === 's.whatsapp.net') domain = 'c.us';\n    return `${digits}@${domain}`;\n  }\n  const digits = s.replace(/\\D/g, '');\n  return digits ? `${digits}@c.us` : s;\n}\nconst chat_id = normalizeChatId(raw_chat_id);\n\n// --- text body/caption (if present)\nlet body =\n  e?.payload?.body ||\n  e?.payload?.text ||\n  e?.message?.text ||\n  e?.payload?.caption ||\n  '';\n\n// --- media URL (if present)\nconst media_url =\n  e?.payload?.media?.url ||\n  e?.payload?.url ||\n  e?.payload?.mediaUrl ||\n  e?.message?.media?.url ||\n  '';\n\n// --- skip echoes / fromMe (best-effort)\nconst should_skip = Boolean(\n  e?.payload?.fromMe === true ||\n  e?.payload?.fromMe === 'true' ||\n  e?.message?.fromMe === true ||\n  e?.message?.fromMe === 'true'\n);\n\n// --- command: /tax4us, /meatpoint etc.\nlet command = null;\nif (typeof body === 'string') {\n  const t = body.trim();\n  if (t.startsWith('/')) {\n    command = t.slice(1).split(/\\s+/)[0].toLowerCase();\n    // strip the command token from the body so the agent sees the actual question\n    body = t.replace(/^\\/[^\\s]+\\s*/,'');\n  }\n}\n\nreturn [{\n  json: {\n    ...e,\n    session_id,\n    chat_id,\n    message_type,\n    content: body,\n    media_url,\n    command,\n    should_skip\n  }\n}];\n"
      },
