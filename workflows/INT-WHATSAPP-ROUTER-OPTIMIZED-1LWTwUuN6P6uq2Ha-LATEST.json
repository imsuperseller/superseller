    {
      "parameters": {
        "jsCode": "// Prepare input for AI Agent (system + user prompt)\nconst item = $input.first().json;\n\nconst message_type = item.message_type || 'text';\nconst content = (item.text || item.content || '').toString();\nconst media_url = item.media_url || '';\nconst customer_config = item.customer_config || {};\n\nconst globalSystem =\n  item.CONFIG?.global_system_prompt ||\n  [\n    \"You are an AI assistant operating inside WhatsApp. Follow these rules:\",\n    \"\",\n    \"SAFETY & SCOPE\",\n    \"- Stay strictly within the customer's business scope and policies.\",\n    \"- If the user asks for disallowed content, refuse briefly and redirect to a business-related alternative.\",\n    \"- If uncertain, ask ONE clarifying question, then stop.\",\n    \"\",\n    \"TOOLS\",\n    \"- You may use available tools only when necessary to answer correctly.\",\n    \"- If you used a tool, incorporate its result into the response. Do not mention internal node names.\",\n    \"\",\n    \"STYLE (WhatsApp)\",\n    \"- Keep replies short and actionable.\",\n    \"- Use plain text. No long explanations.\",\n    \"- Prefer: 1–4 short lines, then one question if needed.\",\n    \"\",\n    \"OUTPUT\",\n    \"- Return the final message text only.\"\n  ].join(\"\\n\");\n\nconst customerSystem = (customer_config.system_prompt || '').toString();\n\nconst systemMessage =\n  `${globalSystem}\\n\\n` +\n  `${customerSystem}\\n\\n` +\n  `Runtime: You are handling a ${message_type} message.`;\n\nconst chatInput =\n  `USER_MESSAGE:\\n${content || \"(no text)\"}\\n\\n` +\n  `CONTEXT:\\n` +\n  `- customer: ${customer_config.customer_id || \"default\"} (${customer_config.customer_name || \"Customer\"})\\n` +\n  `- message_type: ${message_type}\\n` +\n  `- media_url: ${media_url || \"none\"}\\n` +\n  `- user_chat_id: ${item.chat_id || item.chatId || \"unknown\"}\\n` +\n  `- session: ${item.session_id || item.session || \"default\"}\\n`;\n\nreturn [{\n  json: {\n    ...item,\n    chatInput,\n    systemMessage\n  }\n}];"
      },
