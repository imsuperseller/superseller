    {
      "parameters": {
        "jsCode": "// Format AI response for WAHA sendText/sendVoice\nconst item = $input.first().json;\n\nconst customer_config = item.customer_config || {};\nconst original_message_type = item.message_type || item.original_message_type || 'text';\n\nconst response_text = (item.output || item.response_text || item.text || '').toString();\n\nfunction normalizeChatId(v) {\n  if (!v) return '';\n  const s = String(v).trim();\n  if (s.includes('@')) {\n    const [id, domainRaw] = s.split('@');\n    const digits = id.replace(/\\D/g, '');\n    const domain = (domainRaw === 's.whatsapp.net') ? 'c.us' : domainRaw;\n    return `${digits}@${domain}`;\n  }\n  const digits = s.replace(/\\D/g, '');\n  return digits ? `${digits}@c.us` : s;\n}\n\nconst session =\n  item.session_id ||\n  item.session ||\n  item.sessionId ||\n  customer_config.waha_session ||\n  'default';\n\nconst chatId = normalizeChatId(item.chat_id || item.chatId || '');\n\nconst voiceEnabled = (customer_config.features_enabled?.voice === true);\n\n// Voice rule: only if customer allows voice AND either inbound was audio OR response is short\nconst send_as_voice =\n  voiceEnabled &&\n  (original_message_type === 'audio' || response_text.length > 0 && response_text.length < 500);\n\nreturn {\n  json: {\n    ...item,\n    session,\n    chatId,\n    text: response_text,\n    response_text,\n    send_as_voice,\n    customer_config,\n    original_message_type\n  }\n};"
      },
