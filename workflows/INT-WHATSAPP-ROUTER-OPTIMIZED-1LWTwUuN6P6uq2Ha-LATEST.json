    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst customer_config = item.customer_config || {};\nconst message_type = item.message_type || 'text';\nconst content = item.content || item.text || '';\n\nlet chatInput = content;\n\nif (message_type === 'audio') {\n  chatInput = (item.text || content || '').toString() + '\\n\\n[Note: Voice message transcription]';\n} else if (message_type === 'image') {\n  chatInput = (content || 'User sent an image.').toString() + '\\n\\n[Note: Image]';\n} else if (message_type === 'video') {\n  chatInput = (content || 'User sent a video.').toString() + '\\n\\n[Note: Video]';\n} else if (message_type === 'document') {\n  chatInput = (content || 'User sent a document.').toString() + '\\n\\n[Note: Document]';\n}\n\nconst global_system_prompt = (item.global_system_prompt || item.CONFIG?.global_system_prompt || '').toString().trim();\nconst customer_system_prompt = (customer_config.system_prompt || '').toString().trim();\n\nconst systemMessage =\n  (global_system_prompt ? global_system_prompt + '\\n\\n' : '') +\n  customer_system_prompt +\n  `\\n\\n[Runtime]\\nmessage_type=${message_type}`;\n\nreturn [{\n  json: {\n    ...item,\n    chatInput,\n    systemMessage,\n    message_type,\n    customer_config,\n    sessionId: item.session_id,\n    session_id: item.session_id,\n    chat_id: item.chat_id,\n    chatId: item.chat_id\n  }\n}];"
      },
      "id": "af41e804-842a-4692-90a2-0322637563f6",
      "name": "✍️ Prepare AI Input2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2928,
        400
      ]
