    {
      "parameters": {
        "jsCode": "// Customer Configuration Lookup (in-memory fallback)\n// Routes by command (/tax4us, /meatpoint) first, then by phone mapping, else default.\n\nconst item = $input.first().json;\n\nconst command = (item.command || '').toString().trim().toLowerCase();\nconst rawChatId = (item.chat_id || item.chatId || '').toString().trim();\n\nfunction normalizeChatId(v) {\n  if (!v) return '';\n  const s = String(v).trim();\n  if (s.includes('@')) {\n    const [id, domainRaw] = s.split('@');\n    const digits = id.replace(/\\D/g, '');\n    const domain = (domainRaw === 's.whatsapp.net') ? 'c.us' : domainRaw;\n    return `${digits}@${domain}`;\n  }\n  const digits = s.replace(/\\D/g, '');\n  return digits ? `${digits}@c.us` : s;\n}\n\nconst chatId = normalizeChatId(rawChatId);\nconst phoneDigits = chatId ? chatId.split('@')[0] : '';\n\nconst customerDB = {\n  tax4us: {\n    customer_id: 'tax4us',\n    customer_name: 'Tax4US',\n    ai_model: 'gpt-4o-mini',\n    system_prompt: 'You are a helpful tax consultant AI for Tax4US. Assist with tax questions, filing, deductions, and compliance. Be professional, accurate, and cautious: if info is missing, ask one clarifying question.',\n    features_enabled: { voice: true, image: true, docs: true, video: false },\n    phone_numbers: ['+972501234567'],\n    waha_session: 'default'\n  },\n  meatpoint: {\n    customer_id: 'meatpoint',\n    customer_name: 'MeatPoint',\n    ai_model: 'gpt-4o-mini',\n    system_prompt: 'You are a helpful restaurant operations + customer service assistant for MeatPoint in Dallas. Be concise, practical, and focused on restaurant operations and guest experience. When relevant, propose automation/WhatsApp agent improvements.',\n    features_enabled: { voice: true, image: true, docs: false, video: false },\n    phone_numbers: ['+19725551234'],\n    waha_session: 'default'\n  },\n  default: {\n    customer_id: 'default',\n    customer_name: 'Rensto Demo',\n    ai_model: 'gpt-4o-mini',\n    system_prompt: \"You are Rensto's WhatsApp demo agent. Keep replies short, confident, and business-focused. Move the conversation toward booking a call / building a WhatsApp agent. Ask at most one clarifying question when needed.\",\n    features_enabled: { voice: true, image: true, docs: true, video: false },\n    phone_numbers: [],\n    waha_session: 'default'\n  }\n};\n\nlet customer = customerDB.default;\n\n// 1) Command routing\nif (command && customerDB[command]) {\n  customer = customerDB[command];\n}\n\n// 2) Phone routing (optional)\nif (customer.customer_id === 'default' && phoneDigits) {\n  for (const key of Object.keys(customerDB)) {\n    const cfg = customerDB[key];\n    const match = (cfg.phone_numbers || []).some(p => p.replace(/\\D/g,'') === phoneDigits);\n    if (match) { customer = cfg; break; }\n  }\n}\n\nconst routing_method =\n  (command && customerDB[command]) ? 'command' :\n  (customer.customer_id !== 'default') ? 'phone' : 'default';\n\nreturn [{\n  json: {\n    ...item,\n    chat_id: chatId,\n    chatId,\n    customer_config: customer,\n    routing_method\n  }\n}];"
      },
      "id": "7fcf3399-1fe9-4a9c-a5ea-d10fc38f59f8",
      "name": "🏷️ Customer Config Lookup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        544
