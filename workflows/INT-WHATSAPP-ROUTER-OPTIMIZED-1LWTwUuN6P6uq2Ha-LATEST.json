    {
      "parameters": {
        "jsCode": "const t = $json.message_type || 'unknown';\nconst biz = $json.customer_config?.customer_name || $json.customer_config?.customer_id || 'this business';\n\nconst session = $json.session_id || $json.session || ($json.CONFIG?.waha_session) || 'default';\nconst chatId = $json.chat_id || $json.chatId;\n\nconst msg = `(${biz}) I can't process ${t} messages here. Please send text.`;\n\nreturn [{\n  json: {\n    ...$json,\n    session,\n    chatId,\n    text: msg,\n    response_text: msg,\n    send_as_voice: false\n  }\n}];"
      },
