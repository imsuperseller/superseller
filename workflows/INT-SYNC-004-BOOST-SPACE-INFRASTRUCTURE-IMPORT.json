    {
      "parameters": {
        "jsCode": "// Generic filter for infrastructure imports\n// Adapts to different CSV structures (Credentials, Nodes, Integrations)\nconst allInputs = $input.all();\nconst existingData = allInputs.find(item => item.json.id || Array.isArray(item.json));\nconst csvData = allInputs.filter(item => !item.json.id && !Array.isArray(item.json));\n\n// Parse existing notes\nconst existing = existingData ? (Array.isArray(existingData.json) ? existingData.json : (existingData.json.data || existingData.json.items || [existingData.json])) : [];\nconst existingTitles = new Set();\nexisting.forEach(note => {\n  if (note.title) existingTitles.add(note.title.toLowerCase());\n});\n\n// Filter CSV items - remove duplicates\n// Try common title fields: Name, Title, Credential Name, Node Name, Integration Name\nconst newItems = [];\nconst seenTitles = new Set();\n\nfor (const item of csvData) {\n  const title = (item.json['Name'] || item.json['Title'] || item.json['Credential Name'] || item.json['Node Name'] || item.json['Integration Name'] || item.json['Platform'] || '').toLowerCase();\n  \n  if (title && !seenTitles.has(title) && !existingTitles.has(title)) {\n    seenTitles.add(title);\n    newItems.push(item);\n  }\n}\n\nreturn newItems;"
      },
