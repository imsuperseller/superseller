{
  "name": "INT-SYNC-005: Export Current n8n Data to CSV v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "export-current-data",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [16, 0],
      "disabled": false
    },
    {
      "parameters": {
        "jsCode": "// Query database for current credentials\nconst db = require('better-sqlite3')('/home/node/.n8n/database.sqlite');\n\nconst credentials = db.prepare(`\n  SELECT \n    id as cred_id,\n    name as \"n8n Nodes\",\n    type as \"Credential Type\",\n    createdAt as Created,\n    updatedAt as \"Last Modified\"\n  FROM credential_entity\n  ORDER BY updatedAt DESC\n`).all();\n\ndb.close();\n\nreturn credentials.map(cred => ({\n  json: cred\n}));"
      },
      "id": "query-db-1",
      "name": "Query Credentials DB",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 0],
      "disabled": false
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "csv-header",
              "name": "csvHeader",
              "value": "cred_id,n8n Nodes,Credential Type,Working?,n8n Reference,Created,Last Modified,Status (AI evaluation),Security Risk (AI Score)",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-header-1",
      "name": "Set CSV Header",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [464, 0],
      "disabled": false
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "csv-rows",
              "name": "csvRows",
              "value": "={{ $('Query Credentials DB').all().map(item => Object.values(item.json).join(',')).join('\\n') }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "format-csv-1",
      "name": "Format CSV",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [688, 0],
      "disabled": false
    },
    {
      "parameters": {
        "fileName": "/tmp/n8n-data/current-credentials-export.csv",
        "fileContent": "={{ $json.csvHeader + '\\n' + $json.csvRows }}",
        "options": {}
      },
      "id": "write-file-1",
      "name": "Write CSV File",
      "type": "n8n-nodes-base.writeBinaryFile",
      "typeVersion": 1,
      "position": [912, 0],
      "disabled": false
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { success: true, file: '/tmp/n8n-data/current-credentials-export.csv', count: $('Query Credentials DB').all().length } }}",
        "options": {}
      },
      "id": "respond-1",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1136, 0],
      "disabled": false
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Query Credentials DB",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Query Credentials DB": {
      "main": [
        [
          {
            "node": "Set CSV Header",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set CSV Header": {
      "main": [
        [
          {
            "node": "Format CSV",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format CSV": {
      "main": [
        [
          {
            "node": "Write CSV File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Write CSV File": {
      "main": [
        [
          {
            "node": "Respond",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": false
  },
  "staticData": {},
  "meta": {},
  "pinData": {},
  "active": false
}

