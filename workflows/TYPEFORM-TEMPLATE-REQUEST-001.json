{
  "name": "TYPEFORM-TEMPLATE-REQUEST-001: Template Request Handler v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "typeform-template-request",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Typeform Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Parse Typeform webhook payload\nconst webhookData = $input.first().json;\nconst formResponse = webhookData.form_response || webhookData;\n\n// Extract answers\nconst answers = {};\nif (formResponse.answers) {\n  formResponse.answers.forEach(answer => {\n    const fieldRef = answer.field?.ref || answer.field?.id || '';\n    if (answer.type === 'email') answers.email = answer.email || '';\n    else if (answer.type === 'text') answers[fieldRef] = answer.text || '';\n    else if (answer.type === 'long_text') answers[fieldRef] = answer.text || '';\n    else if (answer.type === 'choice') answers[fieldRef] = answer.choice?.label || '';\n    else if (answer.type === 'choices') answers[fieldRef] = answer.choices?.labels || [];\n  });\n}\n\nconst requestData = {\n  email: answers.email || answers.Email || '',\n  template_name: answers.template_name || answers['template-name'] || '',\n  description: answers.description || answers.Description || '',\n  tools: Array.isArray(answers.tools || answers.Tools) ? answers.tools || answers.Tools : [],\n  urgency: answers.urgency || answers.Urgency || '',\n  budget: answers.budget || answers.Budget || '',\n  form_id: webhookData.form_id || '',\n  submitted_at: formResponse.submitted_at || new Date().toISOString()\n};\n\nreturn [{\n  json: {\n    success: true,\n    requestData: requestData\n  }\n}];"
      },
      "id": "parse-typeform",
      "name": "Parse Typeform Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "insert",
        "dataTableId": "template_requests",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "template_name": "={{ $json.requestData.template_name }}",
            "description": "={{ $json.requestData.description }}",
            "tools_required": "={{ Array.isArray($json.requestData.tools) ? $json.requestData.tools.join(', ') : ($json.requestData.tools || 'N/A') }}",
            "urgency": "={{ $json.requestData.urgency }}",
            "budget": "={{ $json.requestData.budget }}",
            "status": "New",
            "email": "={{ $json.requestData.email }}",
            "submitted_at": "={{ $json.requestData.submitted_at }}",
            "form_id": "={{ $json.requestData.form_id }}"
          }
        },
        "options": {}
      },
      "id": "create-request",
      "name": "Save Template Request",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "options": {
          "temperature": 0.3
        },
        "messages": {
          "messageValues": [
            {
              "role": "system",
              "content": "You are an automation expert. Analyze the template request and estimate complexity."
            },
            {
              "role": "user",
              "content": "=Template: {{ $json.requestData.template_name }}\\nDescription: {{ $json.requestData.description }}\\nTools: {{ $json.requestData.tools.join(', ') }}\\n\\nEstimate:\\n1. Complexity (Simple/Advanced/Complex)\\n2. Estimated hours\\n3. Recommended approach"
            }
          ]
        }
      },
      "id": "calculate-complexity",
      "name": "Calculate Complexity (OpenAI)",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "channel": "template-requests",
        "text": "=## 🔨 New Template Request\\n\\n**Template:** {{ $('Parse Typeform Data').item.json.requestData.template_name }}\\n**Budget:** {{ $('Parse Typeform Data').item.json.requestData.budget }}\\n**Urgency:** {{ $('Parse Typeform Data').item.json.requestData.urgency }}\\n**Email:** {{ $('Parse Typeform Data').item.json.requestData.email }}\\n\\n{{ $('Parse Typeform Data').item.json.requestData.urgency === 'ASAP (willing to pay premium for fast delivery)' ? '🚨 URGENT REQUEST' : '' }}",
        "otherOptions": {
          "username": "Rensto Bot",
          "icon_emoji": ":hammer:"
        }
      },
      "id": "slack-notify",
      "name": "Notify Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "asap-urgency",
              "leftValue": "={{ $('Parse Typeform Data').item.json.requestData.urgency }}",
              "rightValue": "ASAP (willing to pay premium for fast delivery)",
              "operator": {
