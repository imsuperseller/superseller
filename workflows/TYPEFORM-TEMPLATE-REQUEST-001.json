    {
      "parameters": {
        "to": "={{ $('Parse Typeform Data').item.json.requestData.email }}",
        "subject": "=Template Request Received{{ $('Is ASAP?').item.json.requestData.urgency === 'ASAP (willing to pay premium for fast delivery)' ? ' - We'll Prioritize Your Request!' : '' }}",
        "bodyContent": "=Hi there!\\n\\nThank you for your template request: **{{ $('Parse Typeform Data').item.json.requestData.template_name }}**\\n\\n{{ $('Is ASAP?').item.json.requestData.urgency === 'ASAP (willing to pay premium for fast delivery)' ? '🚨 We've marked your request as URGENT and will prioritize it!' : 'We'll review your request and get back to you within 48 hours.' }}\\n\\n**What happens next:**\\n✓ We'll assess complexity & feasibility\\n✓ Send you a quote + timeline\\n✓ Build the template if approved\\n✓ Deliver with installation guide\\n\\n**Meanwhile:**\\nBrowse our existing templates: https://rensto.com/marketplace\\n\\nBest regards,\\nThe Rensto Team",
        "additionalFields": {
          "contentType": "html"
        }
      },
      "id": "send-email",
      "name": "Send Confirmation Email",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [1560, 200],
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "EA2Fl9QT5h2HZoo9",
          "name": "rensto"
        }
      }
