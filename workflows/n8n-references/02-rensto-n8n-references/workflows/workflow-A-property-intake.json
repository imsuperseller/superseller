{
    "name": "Nir Sheinbein - Workflow A - Property Intake & Filter",
    "nodes": [
        {
            "parameters": {
                "rule": "cron",
                "cronTime": "0 */4 * * *",
                "timezone": "America/Chicago"
            },
            "id": "cronTrigger",
            "name": "Run Every 4 Hours",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1,
            "position": [
                240,
                300
            ]
        },
        {
            "parameters": {
                "operation": "list",
                "baseId": "appQijHhqqP4z6wGe",
                "tableId": "tbldqyei3vkW4iRFc",
                "filterByFormula": "{Enabled} = TRUE()"
            },
            "id": "airtableSources",
            "name": "Airtable - Get Sources",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                460,
                300
            ],
            "credentials": {
                "airtableApi": {
                    "id": "3lTwFd8waEI1UQEW",
                    "name": "Airtable API"
                }
            }
        },
        {
            "parameters": {
                "batchSize": 1
            },
            "id": "splitInBatches",
            "name": "Process One Source at a Time",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 1,
            "position": [
                680,
                300
            ]
        },
        {
            "parameters": {
                "actorId": "apify/website-content-scraper",
                "input": {
                    "startUrls": [
                        {
                            "url": "{{$json.fields['Start URL']}}"
                        }
                    ],
                    "crawlerType": "playwright:firefox"
                },
                "waitForFinish": true
            },
            "id": "apifyScraper",
            "name": "Apify - Scrape Website",
            "type": "n8n-nodes-apify.apify",
            "typeVersion": 1,
            "position": [
                900,
                300
            ],
            "credentials": {
                "apifyApi": {
                    "id": "YAejSPPe9kH85mYN",
                    "name": "Apify API"
                }
            }
        },
        {
            "parameters": {
                "code": "const criteria = { city: ['Dallas','Plano','Frisco'], minPrice: 150000, maxPrice: 650000, minBeds: 2, minBaths: 1 }; const items = $json.items || []; const qualifiedLeads = []; for (const item of items) { if (!item.address || !item.city || !item.price) continue; if (!criteria.city.includes(item.city)) continue; if (item.price < criteria.minPrice || item.price > criteria.maxPrice) continue; if ((item.beds || 0) < criteria.minBeds) continue; if ((item.baths || 0) < criteria.minBaths) continue; qualifiedLeads.push({ json: item }); } return qualifiedLeads;"
            },
            "id": "filterAndNormalize",
            "name": "Filter & Normalize Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 1,
            "position": [
                1120,
                300
            ]
        },
        {
            "parameters": {
                "operation": "upsert",
                "baseId": "appQijHhqqP4z6wGe",
                "tableId": "tbl7W7k5SpIlaAJom",
                "matchFieldName": "MLS ID",
                "fields": {
                    "MLS ID": "{{$json.mlsId}}",
                    "Status": "Draft",
                    "Source": "MLS",
                    "Property URL": "{{$json.url}}",
                    "Street Address": "{{$json.address}}",
                    "City": "{{$json.city}}",
                    "State": "{{$json.state}}",
                    "ZIP": "{{$json.zip}}",
                    "Year Built": "{{$json.yearBuilt}}",
                    "Offer Amount (USD)": "{{$json.price}}",
                    "Is Rented": "{{$json.rented}}"
                }
            },
            "id": "airtableUpsert",
            "name": "Airtable - Upsert Offer",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                1340,
                300
            ],
            "credentials": {
                "airtableApi": {
                    "id": "3lTwFd8waEI1UQEW",
                    "name": "Airtable API"
                }
            }
        }
    ],
    "connections": {
        "cronTrigger": {
            "main": [
                [
                    {
                        "node": "airtableSources",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "airtableSources": {
            "main": [
                [
                    {
                        "node": "splitInBatches",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "splitInBatches": {
            "main": [
                [
                    {
                        "node": "apifyScraper",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "apifyScraper": {
            "main": [
                [
                    {
                        "node": "filterAndNormalize",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "filterAndNormalize": {
            "main": [
                [
                    {
                        "node": "airtableUpsert",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionTimeout": 300
    }
}