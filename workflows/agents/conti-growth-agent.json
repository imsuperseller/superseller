{
    "name": "CON-GROW-001: Conti Growth Agent",
    "nodes": [
        {
            "parameters": {
                "updates": [
                    "message"
                ],
                "additionalFields": {}
            },
            "id": "telegram-trigger",
            "name": "Telegram - New Request",
            "type": "n8n-nodes-base.telegramTrigger",
            "typeVersion": 1,
            "position": [
                240,
                300
            ],
            "webhookId": "conti-telegram-trigger"
        },
        {
            "parameters": {
                "url": "https://api.apify.com/v2/acts/karamelo~youtube-transcripts/run-sync-get-dataset-items",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "Bearer apify_api_SMA1HfBPNRoiTqqPEKdA0NwfsdQilM17Nb2X"
                        }
                    ]
                },
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "videoUrls",
                            "value": "={{ $json.message.text }}"
                        }
                    ]
                },
                "options": {}
            },
            "id": "apify-transcript",
            "name": "Apify - YouTube Transcript",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                460,
                300
            ]
        },
        {
            "parameters": {
                "model": "claude-3-5-sonnet-latest",
                "prompt": "Summarize this transcript into a viral social media post and 3 hooks: {{ $json.text }}",
                "options": {}
            },
            "id": "anthropic-ai",
            "name": "Anthropic - Synthesize Content",
            "type": "n8n-nodes-base.anthropic",
            "typeVersion": 1,
            "position": [
                680,
                300
            ]
        },
        {
            "parameters": {
                "operation": "post",
                "instance": "WAHA_PRO_1",
                "recipient": "={{ $node[\"Telegram - New Request\"].first().json.message.chat.id }}",
                "message": "={{ $json.content }}"
            },
            "id": "waha-send",
            "name": "WAHA - Post to Social/WA",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                900,
                300
            ]
        }
    ],
    "connections": {
        "Telegram - New Request": {
            "main": [
                [
                    {
                        "node": "Apify - YouTube Transcript",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Apify - YouTube Transcript": {
            "main": [
                [
                    {
                        "node": "Anthropic - Synthesize Content",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Anthropic - Synthesize Content": {
            "main": [
                [
                    {
                        "node": "WAHA - Post to Social/WA",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionOrder": "v1",
        "availableInMCP": true
    }
}