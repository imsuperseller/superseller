            "position": [
                450,
                300
            ]
        },
        {
            "parameters": {
                "url": "https://firestore.googleapis.com/v1/projects/rensto-3f9f6/databases/(default)/documents/leads?documentId={{ $json.body.user_id }}",
                "method": "PATCH",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "jsonBody": "={{ { fields: { name: { stringValue: $json.body.full_name }, email: { stringValue: $json.body.email }, arr: { integerValue: $json.body.arr_millions }, status: { stringValue: 'new' }, tier: { stringValue: 'whale' } } } }}"
            },
            "name": "Save Whale Lead",
