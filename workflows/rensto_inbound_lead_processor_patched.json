            "name": "ManyChat Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                250,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "number": [
                        {
                            "value1": "={{ $json.body.arr_millions }}",
                            "operation": "largerEqual",
                            "value2": 10
                        },
                        {
                            "value1": "={{ $json.body.arr_millions }}",
                            "operation": "largerEqual",
                            "value2": 2
