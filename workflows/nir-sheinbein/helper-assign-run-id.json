{
    "name": "Helper - Assign Run ID for Real Estate Offers",
    "nodes": [
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "minutes",
                            "value": 1
                        }
                    ]
                }
            },
            "id": "scheduleTrigger",
            "name": "Run Every Minute",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.1,
            "position": [
                240,
                300
            ]
        },
        {
            "parameters": {
                "operation": "list",
                "baseId": "appQijHhqqP4z6wGe",
                "tableId": "tbl7W7k5SpIlaAJom",
                "filterByFormula": "{Run ID} = BLANK()",
                "limit": 10
            },
            "id": "airtableGetNew",
            "name": "Airtable - Get New Offers",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                460,
                300
            ],
            "credentials": {
                "airtableApi": {
                    "id": "3lTwFd8waEI1UQEW",
                    "name": "Airtable API"
                }
            }
        },
        {
            "parameters": {
                "operation": "list",
                "baseId": "appQijHhqqP4z6wGe",
                "tableId": "tbl7W7k5SpIlaAJom",
                "sorts": [
                    {
                        "field": "Run ID",
                        "direction": "desc"
                    }
                ],
                "limit": 1
            },
            "id": "airtableGetHighest",
            "name": "Airtable - Get Highest ID",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                680,
                300
            ],
            "credentials": {
                "airtableApi": {
                    "id": "3lTwFd8waEI1UQEW",
                    "name": "Airtable API"
                }
            }
        },
        {
            "parameters": {
                "code": "const highestId = $items('Airtable - Get Highest ID')[0].json.fields['Run ID'] || 0; const newRecords = $items('Airtable - Get New Offers'); let currentId = highestId; for (const record of newRecords) { currentId++; record.json.fields['Run ID'] = currentId; record.json.fields['Generate Offer URL'] = `https://rensto.n8n.cloud/webhook/generate-offer?recordId=${record.json.id}`; } return newRecords;"
            },
            "id": "assignIds",
            "name": "Assign New IDs & URLs",
            "type": "n8n-nodes-base.code",
            "typeVersion": 1,
            "position": [
                900,
                300
            ]
        },
        {
            "parameters": {
                "operation": "update",
                "baseId": "appQijHhqqP4z6wGe",
                "tableId": "tbl7W7k5SpIlaAJom",
                "records": [
                    {
                        "id": "{{$json.id}}",
                        "fields": {
                            "Run ID": "{{$json.fields['Run ID']}}",
                            "Generate Offer URL": "{{$json.fields['Generate Offer URL']}}"
                        }
                    }
                ]
            },
            "id": "airtableUpdate",
            "name": "Airtable - Update Records",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                1120,
                300
            ],
            "credentials": {
                "airtableApi": {
                    "id": "3lTwFd8waEI1UQEW",
                    "name": "Airtable API"
                }
            }
        }
    ],
    "connections": {
        "scheduleTrigger": {
            "main": [
                [
                    {
                        "node": "airtableGetNew",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "airtableGetNew": {
            "main": [
                [
                    {
                        "node": "airtableGetHighest",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "airtableGetHighest": {
            "main": [
                [
                    {
                        "node": "assignIds",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "assignIds": {
            "main": [
                [
                    {
                        "node": "airtableUpdate",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionTimeout": 60
    }
}