{
  "name": "INT-VPS-001: Upload CSV to VPS",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger-1",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "fileName": "=/Users/shaifriedman/New Rensto/rensto/scripts/boost-space/exports/products.csv",
        "options": {}
      },
      "id": "read-csv-1",
      "name": "Read CSV File",
      "type": "n8n-nodes-base.readBinaryFile",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "// Convert binary data to base64 for SSH transfer\nconst binaryData = $input.first().binary.data;\nconst base64Data = binaryData.data.toString('base64');\n\nreturn [{\n  json: {\n    base64Data: base64Data,\n    fileName: 'products.csv'\n  }\n}];"
      },
      "id": "convert-base64-1",
      "name": "Convert to Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "host": "173.254.201.134",
        "port": 22,
        "username": "root",
        "password": "necmad-zYnfe4-fypwip",
        "command": "=mkdir -p /tmp && echo '{{ $json.base64Data }}' | base64 -d > /tmp/products.csv && ls -lh /tmp/products.csv"
      },
      "id": "upload-csv-1",
      "name": "Upload CSV to VPS",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1.1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "host": "173.254.201.134",
        "port": 22,
        "username": "root",
        "password": "necmad-zYnfe4-fypwip",
        "command": "docker exec n8n_rensto mkdir -p /home/node/.n8n/data && docker cp /tmp/products.csv n8n_rensto:/home/node/.n8n/data/products.csv && docker exec n8n_rensto ls -la /home/node/.n8n/data/products.csv"
      },
      "id": "copy-to-container-1",
      "name": "Copy CSV to Container",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1.1,
      "position": [900, 300]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Read CSV File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Read CSV File": {
      "main": [
        [
          {
            "node": "Convert to Base64",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Convert to Base64": {
      "main": [
        [
          {
            "node": "Upload CSV to VPS",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Upload CSV to VPS": {
      "main": [
        [
          {
            "node": "Copy CSV to Container",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}

