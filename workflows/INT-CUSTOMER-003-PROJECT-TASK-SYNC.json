    {
      "parameters": {
        "jsCode": "// Prepare comprehensive sync response\nconst projectData = $('Find Project in Boost.space').first().json;\nconst taskData = $('Create Task in Boost.space').first().json;\nconst inputData = $('Validate Input Data').first().json;\n\nconst response = {\n  success: true,\n  message: 'Project-Task data integrated successfully',\n  data: {\n    project: {\n      id: projectData.id,\n      name: projectData.name,\n      customerId: projectData.customer\n    },\n    task: {\n      id: taskData.id,\n      title: taskData.title || inputData.taskTitle,\n      projectId: projectData.id,\n      status: taskData.status_system_id || inputData.taskStatus\n    }\n  },\n  timestamp: new Date().toISOString(),\n  workflow: 'INT-CUSTOMER-003: Project-Task Data Integration v1'\n};\n\nreturn [{ json: response }];"
      },
