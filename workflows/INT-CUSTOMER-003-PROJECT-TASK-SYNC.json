    {
      "parameters": {
        "jsCode": "// Update project metadata with task reference\nconst projectData = $('Find Project in Boost.space').first().json;\nconst taskData = $('Create Task in Boost.space').first().json;\nconst inputData = $('Validate Input Data').first().json;\n\n// Get existing tasks or initialize\nconst existingTasks = projectData.metadata?.tasks || [];\nexistingTasks.push({\n  taskId: taskData.id,\n  taskTitle: inputData.taskTitle,\n  createdAt: new Date().toISOString()\n});\n\nreturn [{\n  json: {\n    projectId: projectData.id,\n    taskId: taskData.id,\n    tasks: existingTasks\n  }\n}];"
      },
