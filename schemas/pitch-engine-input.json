{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cinematic Ego-Pitch Engine Input",
    "description": "Input data required to generate a hyper-personalized cinematic pitch video.",
    "type": "object",
    "required": [
        "prospect",
        "business",
        "context"
    ],
    "properties": {
        "prospect": {
            "type": "object",
            "description": "Data about the target prospect.",
            "required": [
                "name",
                "company"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Full name of the prospect (e.g., 'Gordon Ramsay')."
                },
                "role": {
                    "type": "string",
                    "description": "Job title (e.g., 'Owner', 'Head Chef')."
                },
                "company": {
                    "type": "string",
                    "description": "Business name (e.g., 'Hell's Kitchen')."
                },
                "website": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of their website."
                },
                "niche": {
                    "type": "string",
                    "description": "Specific industry niche (e.g., 'Fine Dining', 'Fast Food')."
                },
                "pain_points": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of known or inferred pains (e.g., 'No-shows', 'Staff turnover')."
                },
                "socials": {
                    "type": "object",
                    "properties": {
                        "linkedin": {
                            "type": "string"
                        },
                        "twitter": {
                            "type": "string"
                        },
                        "instagram": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "business": {
            "type": "object",
            "description": "Data about the pitching business (Rensto or Client).",
            "required": [
                "name",
                "offer"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Name of the pitching agency/business."
                },
                "offer": {
                    "type": "string",
                    "description": "Core value proposition (e.g., 'Automated reservation recovery')."
                },
                "pricing_tiers": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "price": {
                                "type": "string"
                            },
                            "features": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "case_studies": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "client_name": {
                                "type": "string"
                            },
                            "result": {
                                "type": "string"
                            }
                        }
                    }
                },
                "visual_identity": {
                    "type": "object",
                    "properties": {
                        "logo_url": {
                            "type": "string"
                        },
                        "primary_color": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "context": {
            "type": "object",
            "description": "Context of the pitch.",
            "required": [
                "source"
            ],
            "properties": {
                "source": {
                    "type": "string",
                    "enum": [
                        "form",
                        "whatsapp",
                        "linkedin_dm",
                        "website_visit",
                        "referral",
                        "cold_outbound"
                    ],
                    "description": "Where the lead came from."
                },
                "campaign_id": {
                    "type": "string",
                    "description": "ID of the marketing campaign if applicable."
                },
                "relationship_stage": {
                    "type": "string",
                    "enum": [
                        "cold",
                        "warm",
                        "meeting_booked",
                        "proposal_sent",
                        "client"
                    ],
                    "default": "cold"
                }
            }
        },
        "config": {
            "type": "object",
            "description": "Optional configuration overrides for the engine.",
            "properties": {
                "force_template": {
                    "type": "string",
                    "enum": [
                        "temple",
                        "shark_tank",
                        "game_show",
                        "movie_trailer",
                        "coronation"
                    ],
                    "description": "Force a specific template ID."
                },
                "video_duration_seconds": {
                    "type": "integer",
                    "minimum": 15,
                    "maximum": 60,
                    "default": 30
                }
            }
        }
    }
}