{
  "name": "WordPress Blog & Posts Agent - Tax4Us (Optimized)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ben-wordpress-blog",
        "responseMode": "responseNode",
        "options": {
          "responseHeaders": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      },
      "id": "webhook-trigger",
      "name": "WordPress Blog Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        240,
        300
      ],
      "webhookId": "ben-wordpress-blog"
    },
    {
      "parameters": {
        "model": "gpt-4",
        "prompt": "Research trending tax topics for blog posts. Focus on current tax laws, deductions, and financial planning. Generate 5 blog post ideas with titles, outlines, and target keywords. Format as JSON array with title, outline, keywords, and estimated_read_time.",
        "options": {
          "temperature": 0.8,
          "maxTokens": 1500
        }
      },
      "id": "research-topics",
      "name": "Research Blog Topics",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        460,
        200
      ],
      "credentials": {
        "openAiApi": {
          "id": "ben-openai-api",
          "name": "Ben OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "model": "gpt-4",
        "prompt": "Generate a comprehensive blog post for a tax services website. Topic: {{ $json.topic }}. Include introduction, main sections, conclusion, and call-to-action. Format as JSON with title, content, meta_description, keywords, featured_image_suggestion, and publish_date.",
        "options": {
          "temperature": 0.7,
          "maxTokens": 3000
        }
      },
      "id": "generate-blog-post",
      "name": "Generate Blog Post",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        680,
        200
      ],
      "credentials": {
        "openAiApi": {
          "id": "ben-openai-api",
          "name": "Ben OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "resource": "post",
        "title": "={{ $json.title }}",
        "content": "={{ $json.content }}",
        "status": "publish",
        "additionalFields": {
          "categories": [
            "Tax Services",
            "Financial Planning"
          ],
          "tags": "={{ $json.keywords.split(',') }}",
          "meta": {
            "description": "={{ $json.meta_description }}",
            "keywords": "={{ $json.keywords }}"
          },
          "featured_media": "={{ $json.featured_image_suggestion }}"
        }
      },
      "id": "publish-blog-post",
      "name": "Publish Blog Post",
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [
        900,
        200
      ],
      "credentials": {
        "wordpressApi": {
          "id": "ben-wordpress-api",
          "name": "Ben WordPress API"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "resource": "post",
        "title": "={{ $json.title }}",
        "content": "={{ $json.content }}",
        "status": "draft",
        "additionalFields": {
          "categories": [
            "Tax Services",
            "Financial Planning"
          ],
          "tags": "={{ $json.keywords.split(',') }}",
          "meta": {
            "description": "={{ $json.meta_description }}",
            "keywords": "={{ $json.keywords }}"
          }
        }
      },
      "id": "save-draft",
      "name": "Save as Draft",
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [
        900,
        400
      ],
      "credentials": {
        "wordpressApi": {
          "id": "ben-wordpress-api",
          "name": "Ben WordPress API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "publish-mode",
              "leftValue": "={{ $json.publishMode }}",
              "rightValue": "publish",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "publish-decision",
      "name": "Publish Decision",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"Blog post published successfully\",\n  \"data\": {\n    \"post_id\": \"{{ $json.id }}\",\n    \"title\": \"{{ $json.title }}\",\n    \"url\": \"{{ $json.link }}\",\n    \"status\": \"published\",\n    \"published_at\": \"{{ $json.date }}\"\n  }\n}"
      },
      "id": "success-response",
      "name": "Success Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1120,
        200
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"Blog post saved as draft\",\n  \"data\": {\n    \"post_id\": \"{{ $json.id }}\",\n    \"title\": \"{{ $json.title }}\",\n    \"url\": \"{{ $json.link }}\",\n    \"status\": \"draft\",\n    \"created_at\": \"{{ $json.date }}\"\n  }\n}"
      },
      "id": "draft-response",
      "name": "Draft Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1120,
        400
      ]
    }
  ],
  "connections": {
    "WordPress Blog Webhook": {
      "main": [
        [
          {
            "node": "Research Blog Topics",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Research Blog Topics": {
      "main": [
        [
          {
            "node": "Generate Blog Post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Blog Post": {
      "main": [
        [
          {
            "node": "Publish Decision",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Publish Decision": {
      "main": [
        [
          {
            "node": "Publish Blog Post",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Save Draft",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Publish Blog Post": {
      "main": [
        [
          {
            "node": "Success Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save Draft": {
      "main": [
        [
          {
            "node": "Draft Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "1",
  "meta": {
    "templateCredsSetupCompleted": false
  },
  "id": "wordpress-blog-agent-optimized",
  "tags": [
    {
      "id": "wordpress",
      "name": "WordPress"
    },
    {
      "id": "blog",
      "name": "Blog"
    },
    {
      "id": "content",
      "name": "Content"
    },
    {
      "id": "tax-services",
      "name": "Tax Services"
    }
  ]
}