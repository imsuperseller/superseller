        {
            "parameters": {
                "model": "gpt-4o-2024-11-20",
                "prompt": "Research trending tax topics and content opportunities for Tax4Us using the provided search results and your knowledge. Focus on:\n\n1. Current tax law changes and updates\n2. Seasonal tax topics (filing deadlines, deductions)\n3. Industry trends and competitor content gaps\n4. SEO opportunities with high search volume\n5. Client pain points and common questions\n\nSearch Results: {{ $('Tavily Search Research').item.json.answer }}\n\nGenerate 5 content ideas with:\n- Title\n- Target keywords\n- Content type (blog post, guide, FAQ)\n- Target audience\n- Estimated word count\n- SEO potential score (1-10)\n- Business value score (1-10)\n\nFormat as JSON array with these fields: title, keywords, contentType, targetAudience, wordCount, seoScore, businessValue, topic, status.",
                "options": {
                    "temperature": 0.7,
                    "maxTokens": 2000
                }
            },
            "id": "ai-research",
            "name": "AI Content Research",
            "type": "n8n-nodes-base.openAi",
            "typeVersion": 1,
            "position": [
                460,
                200
            ],
            "credentials": {
                "openAiApi": {
                    "id": "ben-openai-api",
                    "name": "Ben OpenAI API"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Process AI research results and filter high-value content\nconst researchData = $input.first().json;\nconsole.log('Processing AI research results:', researchData);\n\n// Parse the AI response\nlet contentIdeas = [];\ntry {\n  // Extract JSON from AI response\n  const text = researchData.text || researchData.content || '';\n  const jsonMatch = text.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n  \n  if (jsonMatch) {\n    contentIdeas = JSON.parse(jsonMatch[0]);\n  } else {\n    // Fallback: try to parse the entire response\n    contentIdeas = JSON.parse(text);\n  }\n} catch (error) {\n  console.error('Error parsing AI response:', error);\n  // Create fallback content ideas\n  contentIdeas = [\n    {\n      title: 'Tax Deduction Tips for Small Business Owners',\n      keywords: ['tax deductions', 'small business', 'israel'],\n      contentType: 'blog post',\n      targetAudience: 'small business owners',\n      wordCount: 1500,\n      seoScore: 8,\n      businessValue: 9,\n      topic: 'tax optimization',\n      status: 'New'\n    }\n  ];\n}\n\n// Filter for high-value content (SEO score >= 7 and business value >= 7)\nconst highValueContent = contentIdeas.filter(idea => \n  (idea.seoScore || 5) >= 7 && (idea.businessValue || 5) >= 7\n);\n\nconsole.log(`Found ${highValueContent.length} high-value content ideas`);\n\nreturn highValueContent.map(idea => ({\n  json: {\n    ...idea,\n    timestamp: new Date().toISOString(),\n    source: 'ai_research',\n    priority: 'high',\n    customer: 'Tax4Us'\n  }\n}));"
            },
            "id": "filter-content",
            "name": "Filter High-Value Content",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                680,
                200
            ]
        },
