                    }
                ]
            ]
        },
        "Update Airtable Status": {
            "main": [
                [
                    {
                        "node": "Create Performance Record",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Create Performance Record": {
            "main": [
                [
                    {
                        "node": "Log Success & Summary",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Log Success & Summary": {
            "main": [
                [
                    {
