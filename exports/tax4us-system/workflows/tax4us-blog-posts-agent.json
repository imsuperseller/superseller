{
    "name": "Tax4Us Blog & Posts Agent",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "blog-posts-agent",
                "options": {}
            },
            "id": "webhook-trigger",
            "name": "Blog Posts Trigger",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                240,
                300
            ]
        },
        {
            "parameters": {
                "operation": "read",
                "baseId": "appMy8sh7O6b4CPfU",
                "tableId": "tblHaJjvTmU7EjEzM",
                "readAll": false,
                "options": {
                    "filterByFormula": "{Status} = 'New'"
                }
            },
            "id": "get-pending-content",
            "name": "Get Pending Content Requests",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                460,
                200
            ],
            "credentials": {
                "airtableApi": {
                    "id": "tax4us-airtable-api",
                    "name": "Tax4Us Airtable API"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Process pending content requests\nconst records = $input.first().json;\nconsole.log('Processing pending content requests:', records.length);\n\nif (!records || records.length === 0) {\n  return {\n    json: {\n      message: 'No pending content requests found',\n      status: 'no_requests',\n      timestamp: new Date().toISOString()\n    }\n  };\n}\n\n// Take the first pending request\nconst contentRequest = records[0];\nconsole.log('Processing content request:', contentRequest.fields.Title);\n\nreturn {\n  json: {\n    id: contentRequest.id,\n    title: contentRequest.fields.Title,\n    topic: contentRequest.fields.Topic,\n    keywords: contentRequest.fields.Keywords,\n    contentType: contentRequest.fields['Content Type'],\n    targetAudience: contentRequest.fields['Target Audience'],\n    wordCount: contentRequest.fields['Word Count'],\n    language: contentRequest.fields.Language || 'en',\n    slugEn: contentRequest.fields['Slug EN'],\n    slugHe: contentRequest.fields['Slug HE'],\n    notes: contentRequest.fields.Notes,\n    status: 'processing'\n  }\n};"
            },
            "id": "process-request",
            "name": "Process Content Request",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                680,
                200
            ]
        },
        {
            "parameters": {
                "model": "gpt-4o-2024-11-20",
                "prompt": "Create a comprehensive blog post for Tax4Us based on the following specifications:\n\nTitle: {{ $json.title }}\nTopic: {{ $json.topic }}\nKeywords: {{ $json.keywords }}\nTarget Audience: {{ $json.targetAudience }}\nWord Count: {{ $json.wordCount }}\nLanguage: {{ $json.language }}\n\nRequirements:\n1. Write in a professional, educational tone\n2. Include the target keywords naturally\n3. Provide actionable insights and practical advice\n4. Structure with clear headings and subheadings\n5. Include relevant examples and case studies\n6. Optimize for SEO with proper heading structure\n7. Make it engaging and informative for the target audience\n\nFormat the output in Markdown with:\n- H1 for the main title\n- H2 for major sections\n- H3 for subsections\n- Bullet points and numbered lists where appropriate\n- Bold text for emphasis\n\nStart with the title as H1, then create the content body.",
                "options": {
                    "temperature": 0.7,
                    "maxTokens": 4000
                }
            },
            "id": "generate-content",
            "name": "Generate Blog Content",
            "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
            "typeVersion": 1,
            "position": [
                900,
                200
            ],
            "credentials": {
                "openAiApi": {
                    "id": "ben-openai-api",
                    "name": "Ben OpenAI API"
                }
            }
        },
        {
            "parameters": {
                "model": "gpt-4o-2024-11-20",
                "prompt": "Create an SEO-optimized meta description for the following blog post:\n\nTitle: {{ $json.title }}\nContent: {{ $('Generate Blog Content').item.json.text }}\nKeywords: {{ $json.keywords }}\n\nRequirements:\n- Keep it between 150-160 characters\n- Include primary keywords naturally\n- Make it compelling and click-worthy\n- Summarize the main value proposition\n- Include a call to action if appropriate\n\nReturn only the meta description text, no additional formatting.",
                "options": {
                    "temperature": 0.5,
                    "maxTokens": 200
                }
            },
            "id": "generate-meta-description",
            "name": "Generate Meta Description",
            "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
            "typeVersion": 1,
            "position": [
                1120,
                200
            ],
            "credentials": {
                "openAiApi": {
                    "id": "ben-openai-api",
                    "name": "Ben OpenAI API"
                }
            }
        },
        {
            "parameters": {
                "model": "gpt-4o-2024-11-20",
                "prompt": "Create a detailed image prompt for an AI image generation tool to create a featured image for this blog post:\n\nTitle: {{ $json.title }}\nTopic: {{ $json.topic }}\nContent: {{ $('Generate Blog Content').item.json.text }}\n\nRequirements:\n- Create a professional, business-focused image\n- Include relevant visual elements (documents, charts, business people, etc.)\n- Use appropriate colors and lighting\n- Make it engaging and relevant to the topic\n- Specify the style (professional, modern, clean)\n- Include aspect ratio 16:9\n\nReturn only the image prompt text, no additional formatting.",
                "options": {
                    "temperature": 0.7,
                    "maxTokens": 300
                }
            },
            "id": "generate-image-prompt",
            "name": "Generate Image Prompt",
            "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
            "typeVersion": 1,
            "position": [
                1340,
                200
            ],
            "credentials": {
                "openAiApi": {
                    "id": "ben-openai-api",
                    "name": "Ben OpenAI API"
                }
            }
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://www.tax4us.co.il/wp-json/wp/v2/posts",
                "authentication": "predefinedCredentialType",
                "nodeCredentialType": "wordpressApi",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "title",
                            "value": "={{ $json.title }}"
                        },
                        {
                            "name": "content",
                            "value": "={{ $('Generate Blog Content').item.json.text }}"
                        },
                        {
                            "name": "excerpt",
                            "value": "={{ $('Generate Meta Description').item.json.text }}"
                        },
                        {
                            "name": "slug",
                            "value": "={{ $json.slugEn }}"
                        },
                        {
                            "name": "status",
                            "value": "draft"
                        }
                    ]
                },
                "options": {}
            },
            "id": "create-wordpress-post",
            "name": "Create WordPress Post",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1560,
                200
            ],
            "credentials": {
                "wordpressApi": {
                    "id": "wordpress-tax4us-api",
                    "name": "WordPress Tax4Us API"
                }
            }
        },
        {
            "parameters": {
                "operation": "update",
                "baseId": "appMy8sh7O6b4CPfU",
                "tableId": "tblHaJjvTmU7EjEzM",
                "id": "={{ $json.id }}",
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Status": "Complete",
                        "Completed Date": "={{ new Date().toISOString() }}",
                        "WordPress Post ID": "={{ $('Create WordPress Post').item.json.id }}",
                        "WordPress URL": "={{ $('Create WordPress Post').item.json.link }}",
                        "Meta Description": "={{ $('Generate Meta Description').item.json.text }}",
                        "Image Prompt": "={{ $('Generate Image Prompt').item.json.text }}",
                        "Content Length": "={{ $('Generate Blog Content').item.json.text.length }}"
                    }
                }
            },
            "id": "update-airtable-status",
            "name": "Update Airtable Status",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                1780,
                200
            ],
            "credentials": {
                "airtableApi": {
                    "id": "tax4us-airtable-api",
                    "name": "Tax4Us Airtable API"
                }
            }
        },
        {
            "parameters": {
                "operation": "create",
                "baseId": "app6yzlm67lRNuQZD",
                "tableId": "tblContentPerformanceMetrics",
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "Content Title": "={{ $json.title }}",
                        "Customer": "Tax4Us",
                        "Content Type": "Blog Post",
                        "Published Date": "={{ new Date().toISOString() }}",
                        "WordPress Post ID": "={{ $('Create WordPress Post').item.json.id }}",
                        "WordPress URL": "={{ $('Create WordPress Post').item.json.link }}",
                        "Word Count": "={{ $('Generate Blog Content').item.json.text.split(' ').length }}",
                        "SEO Keywords": "={{ $json.keywords }}",
                        "Status": "Published"
                    }
                }
            },
            "id": "create-performance-record",
            "name": "Create Performance Record",
            "type": "n8n-nodes-base.airtable",
            "typeVersion": 1,
            "position": [
                2000,
                200
            ],
            "credentials": {
                "airtableApi": {
                    "id": "rensto-airtable-api",
                    "name": "Rensto Airtable API"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Log successful blog post creation\nconst results = $input.all();\nconsole.log('Blog Posts Agent Results:');\n\nlet summary = {\n  contentRequest: $json,\n  wordpressPost: $('Create WordPress Post').item.json,\n  metaDescription: $('Generate Meta Description').item.json.text,\n  imagePrompt: $('Generate Image Prompt').item.json.text,\n  contentLength: $('Generate Blog Content').item.json.text.length,\n  wordCount: $('Generate Blog Content').item.json.text.split(' ').length,\n  timestamp: new Date().toISOString()\n};\n\nconsole.log('✅ Blog post created successfully!');\nconsole.log(`📝 Title: ${summary.contentRequest.title}`);\nconsole.log(`🔗 WordPress URL: ${summary.wordpressPost.link}`);\nconsole.log(`📊 Word Count: ${summary.wordCount}`);\nconsole.log(`📈 Content Length: ${summary.contentLength} characters`);\n\nreturn {\n  json: {\n    message: 'Blog post created and published successfully!',\n    summary,\n    status: 'success',\n    nextSteps: [\n      'Content is now in WordPress as draft',\n      'Review and publish manually',\n      'Performance tracking activated',\n      'Ready for next content request'\n    ]\n  }\n};"
            },
            "id": "log-success",
            "name": "Log Success & Summary",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2220,
                200
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={{ $json }}",
                "options": {
                    "responseHeaders": {
                        "parameters": [
                            {
                                "name": "Content-Type",
                                "value": "application/json"
                            }
                        ]
                    }
                }
            },
            "id": "respond",
            "name": "Respond",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                2440,
                200
            ]
        }
    ],
    "connections": {
        "Blog Posts Trigger": {
            "main": [
                [
                    {
                        "node": "Get Pending Content Requests",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Get Pending Content Requests": {
            "main": [
                [
                    {
                        "node": "Process Content Request",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Process Content Request": {
            "main": [
                [
                    {
                        "node": "Generate Blog Content",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Generate Blog Content": {
            "main": [
                [
                    {
                        "node": "Generate Meta Description",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Generate Meta Description": {
            "main": [
                [
                    {
                        "node": "Generate Image Prompt",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Generate Image Prompt": {
            "main": [
                [
                    {
                        "node": "Create WordPress Post",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Create WordPress Post": {
            "main": [
                [
                    {
                        "node": "Update Airtable Status",
