{
  "databaseUsers": {
    "rensto_chat_agent": {
      "permissions": [
        "SELECT customers",
        "SELECT orders",
        "INSERT chat_histories"
      ],
      "tables": [
        "customers",
        "orders",
        "chat_histories"
      ],
      "restrictions": [
        "NO UPDATE",
        "NO DELETE",
        "NO DDL"
      ]
    }
  },
  "apiKeys": {
    "chat_agent_key": {
      "permissions": [
        "read_customer_data",
        "write_chat_history"
      ],
      "rateLimit": "100/hour",
      "expiresIn": "30d"
    }
  }
}