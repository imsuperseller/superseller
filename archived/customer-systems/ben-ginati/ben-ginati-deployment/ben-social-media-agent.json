{
  "name": "Social Media Agent - Tax4Us (Optimized)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ben-social-media",
        "responseMode": "responseNode",
        "options": {
          "responseHeaders": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      },
      "id": "webhook-trigger",
      "name": "Social Media Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        240,
        300
      ],
      "webhookId": "ben-social-media"
    },
    {
      "parameters": {
        "model": "gpt-4",
        "prompt": "Generate engaging social media content for a tax services business. Platform: {{ $json.platform }}. Topic: {{ $json.topic }}. Include hashtags, call-to-action, and platform-specific formatting. Format as JSON with content, hashtags, image_suggestion, posting_time, and engagement_tips.",
        "options": {
          "temperature": 0.8,
          "maxTokens": 1000
        }
      },
      "id": "generate-content",
      "name": "Generate Social Content",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        460,
        200
      ],
      "credentials": {
        "openAiApi": {
          "id": "ben-openai-api",
          "name": "Ben OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "resource": "post",
        "message": "={{ $json.content }}",
        "link": "={{ $json.link }}",
        "scheduledPublishTime": "={{ $json.posting_time }}",
        "additionalFields": {
          "privacy": "BUSINESS_PAGE"
        }
      },
      "id": "post-to-facebook",
      "name": "Post to Facebook",
      "type": "n8n-nodes-base.facebook",
      "typeVersion": 1,
      "position": [
        680,
        100
      ],
      "credentials": {
        "facebookApi": {
          "id": "ben-facebook-api",
          "name": "Ben Facebook API"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "resource": "post",
        "text": "={{ $json.content }}",
        "visibility": "public",
        "additionalFields": {
          "scheduledAt": "={{ $json.posting_time }}"
        }
      },
      "id": "post-to-linkedin",
      "name": "Post to LinkedIn",
      "type": "n8n-nodes-base.linkedIn",
      "typeVersion": 1,
      "position": [
        680,
        300
      ],
      "credentials": {
        "linkedInApi": {
          "id": "ben-linkedin-api",
          "name": "Ben LinkedIn API"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "resource": "tweet",
        "text": "={{ $json.content }}",
        "additionalFields": {
          "scheduled_at": "={{ $json.posting_time }}"
        }
      },
      "id": "post-to-twitter",
      "name": "Post to Twitter",
      "type": "n8n-nodes-base.twitter",
      "typeVersion": 1,
      "position": [
        680,
        500
      ],
      "credentials": {
        "twitterApi": {
          "id": "ben-twitter-api",
          "name": "Ben Twitter API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "platform-facebook",
              "leftValue": "={{ $json.platform }}",
              "rightValue": "facebook",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "platform-router",
      "name": "Platform Router",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "platform-linkedin",
              "leftValue": "={{ $json.platform }}",
              "rightValue": "linkedin",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "linkedin-router",
      "name": "LinkedIn Router",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        460,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "platform-twitter",
              "leftValue": "={{ $json.platform }}",
              "rightValue": "twitter",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "twitter-router",
      "name": "Twitter Router",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        460,
        500
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"Social media content posted successfully\",\n  \"data\": {\n    \"platform\": \"{{ $json.platform }}\",\n    \"content\": \"{{ $json.content }}\",\n    \"post_id\": \"{{ $json.id }}\",\n    \"posted_at\": \"{{ $json.created_time }}\",\n    \"engagement_tips\": \"{{ $json.engagement_tips }}\"\n  }\n}"
      },
      "id": "facebook-response",
      "name": "Facebook Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        900,
        100
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"LinkedIn content posted successfully\",\n  \"data\": {\n    \"platform\": \"{{ $json.platform }}\",\n    \"content\": \"{{ $json.content }}\",\n    \"post_id\": \"{{ $json.id }}\",\n    \"posted_at\": \"{{ $json.created_time }}\",\n    \"engagement_tips\": \"{{ $json.engagement_tips }}\"\n  }\n}"
      },
      "id": "linkedin-response",
      "name": "LinkedIn Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"Twitter content posted successfully\",\n  \"data\": {\n    \"platform\": \"{{ $json.platform }}\",\n    \"content\": \"{{ $json.content }}\",\n    \"tweet_id\": \"{{ $json.id }}\",\n    \"posted_at\": \"{{ $json.created_at }}\",\n    \"engagement_tips\": \"{{ $json.engagement_tips }}\"\n  }\n}"
      },
      "id": "twitter-response",
      "name": "Twitter Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        900,
        500
      ]
    }
