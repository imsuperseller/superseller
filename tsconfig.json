{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx"
    // "packages/**/*.ts" — uncomment when adding a monorepo packages/ layer
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "workflows/**",
    "scripts/**",
    "infra/mcp-reference/**",
    "infra/**/*.json",
    "apps/**/node_modules/**",
    "apps/**/.next/**",
    "apps/**/dist/**",
    "apps/**/build/**",
    "**/*.json",
    "**/*.md",
    "**/*.log"
  ]
}