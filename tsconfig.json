{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "archives/**",
    "backups/**",
    "workflows/**",
    "scripts/**",
    "docs/**",
    "Customers/**",
    "data/**",
    "assets/**",
    "products/**",
    "schemas/**",
    "test-payloads/**",
    "rensto-marketplace/**",
    "dima/**",
    "ops/**",
    "configs/**",
    "live-systems/**",
    "packages/**",
    "infra/mcp-reference/**",
    "apps/**/node_modules/**",
    "apps/**/.next/**",
    "apps/**/dist/**",
    "apps/**/build/**"
  ]
}