{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@superseller/db": [
                "./apps/worker-packages/db/src"
            ],
            "@superseller/db/*": [
                "./apps/worker-packages/db/src/*"
            ]
        }
    }
}