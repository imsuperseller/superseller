{
  "mcpServers": {
    "n8n-mcp": {
      "command": "node",
      "args": ["infra/mcp-servers/n8n-mcp-server/server-multi-instance.js"]
    },
    "ai-workflow-generator": {
      "command": "node",
      "args": ["infra/mcp-servers/ai-workflow-generator/server.js"]
    },
    "analytics-reporting": {
      "command": "node",
      "args": ["infra/mcp-servers/analytics-reporting-mcp/server.js"]
    },
    "email-communication": {
      "command": "node",
      "args": ["infra/mcp-servers/email-communication-mcp/server.js"]
    },
    "financial-billing": {
      "command": "node",
      "args": ["infra/mcp-servers/financial-billing-mcp/server.js"]
    },
    "stripe-mcp": {
      "command": "node",
      "args": ["infra/mcp-servers/stripe-mcp-server/server-simple.js"]
    },
    "airtable": {
      "command": "node",
      "args": ["infra/mcp-servers/airtable-mcp-server/server.js"]
    },
    "gsap-master": {
      "command": "npx",
      "args": ["bruzethegreat-gsap-master-mcp-server@latest"]
    },
    "vercel": {
      "command": "npx",
      "args": ["@vercel/mcp-server@latest"]
    },
    "reactbits": {
      "command": "npx",
      "args": ["@reactbits/mcp-server@latest"]
    },
    "react-bits-mcp": {
      "command": "npx",
      "args": ["mcp-remote", "https://react-bits-mcp.davidhzdev.workers.dev/sse"]
    },
    "mui-mcp": {
      "command": "npx",
      "args": ["-y", "@mui/mcp@latest"]
    },
    "typeform": {
      "command": "npx",
      "args": ["@pipedream/mcp-typeform@latest"]
    },
    "esignatures": {
      "command": "npx",
      "args": ["@esignaturescom/mcp-server-esignatures@latest"]
    },
    "quickbooks": {
      "command": "npx",
      "args": ["@quickbooks/mcp-server@latest"]
    },
    "mongodb": {
      "command": "npx",
      "args": ["@mongodb-js/mongodb-mcp-server@latest"]
    },
    "huggingface": {
      "command": "npx",
      "args": ["@huggingface/mcp-server@latest"]
    },
    "rollbar": {
      "command": "npx",
      "args": ["@rollbar/mcp-server@latest"]
    },
    "webflow": {
      "command": "npx",
      "args": ["@webflow/mcp-server@latest"]
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "@jpisnice/shadcn-ui-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your_token_here",
        "SHADCN_FRAMEWORK": "react"
      }
    }
  }
}
