# HYPERISE REPLACEMENT API ENVIRONMENT CONFIGURATION

# Server Configuration
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hyperise_replacement
DB_USER=postgres
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# OpenAI Configuration (for AI personalization)
OPENAI_API_KEY=your-openai-api-key

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760 # 10MB

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://rensto.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Analytics Configuration
ANALYTICS_RETENTION_DAYS=90

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret

# Integration API Keys
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
MAKE_COM_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook
CUSTOMER_CRM_API_KEY=your-customer-crm-api-key

# Production Configuration
# Uncomment and configure for production deployment
# NODE_ENV=production
# BASE_URL=https://your-domain.com
# DB_HOST=your-production-db-host
# DB_PASSWORD=your-production-db-password
# JWT_SECRET=your-production-jwt-secret
# REDIS_URL=redis://your-production-redis-host:6379
