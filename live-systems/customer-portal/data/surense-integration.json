{
  "name": "Surense Make.com Integration",
  "description": "Native Surense module integration for Make.com",
  "apiConfig": {
    "baseUrl": "https://api.surense.co.il/v1",
    "authentication": "bearer_token",
    "headers": {
      "Content-Type": "application/json",
      "Accept": "application/json"
    }
  },
  "endpoints": {
    "customers": {
      "get": "/customers/{id}",
      "create": "/customers",
      "search": "/customers/search",
      "update": "/customers/{id}",
      "delete": "/customers/{id}",
      "portfolio": "/customers/{id}/portfolio-history",
      "related": "/customers/{id}/related"
    },
    "leads": {
      "create": "/leads",
      "get": "/leads/{id}",
      "search": "/leads/search",
      "update": "/leads/{id}",
      "delete": "/leads/{id}"
    },
    "documents": {
      "upload": "/documents/upload",
      "harBituah": "/documents/har-bituah"
    },
    "meetings": {
      "create": "/meetings",
      "get": "/meetings/{id}",
      "search": "/meetings/search",
      "update": "/meetings/{id}",
      "delete": "/meetings/{id}"
    },
    "reports": {
      "create": "/reports",
      "send": "/reports/send"
    }
  },
  "dataMapping": {
    "familyProfile": {
      "clientId": "customer_id",
      "familyMembers": "family_data",
      "insuranceNeeds": "coverage_requirements",
      "riskAssessment": "risk_factors",
      "recommendations": "insurance_recommendations"
    }
  }
}